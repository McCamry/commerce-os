generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  timezone  String    @default("Asia/Bangkok")
  currency  String    @default("THB")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
}

enum Marketplace {
  SHOPEE
  LAZADA
  TIKTOK
  WEBSITE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
}

model Country {
  id        String   @id @default(uuid())
  code      String   @unique
  nameTh    String
  nameEn    String

  provinces Province[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Province {
  id        String   @id @default(uuid())

  countryId String
  country   Country @relation(fields: [countryId], references: [id])

  code      String
  nameTh    String
  nameEn    String

  districts District[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model District {
  id         String   @id @default(uuid())

  provinceId String
  province   Province @relation(fields: [provinceId], references: [id])

  code       String
  nameTh     String
  nameEn     String

  subdistricts Subdistrict[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subdistrict {
  id         String   @id @default(uuid())

  districtId String
  district   District @relation(fields: [districtId], references: [id])

  code       String

  nameTh     String
  nameEn     String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

