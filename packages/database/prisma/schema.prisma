generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUM
//////////////////////////////////////////////////////

enum MarketplaceType {
  SHOPEE
  LAZADA
  TIKTOK
  WEBSITE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum MediaType {
  IMAGE
  VIDEO
}

enum RecordStatus {
  ACTIVE
  INACTIVE
}

//////////////////////////////////////////////////////
// COUNTRY
//////////////////////////////////////////////////////

model Country {
  id String @id @default(uuid())

  code         String  @unique(map: "uk_country_code")
  nameTh       String  @map("name_th")
  nameEn       String  @map("name_en")
  phoneCode    String? @map("phone_code")
  currencyCode String? @map("currency_code")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")

  provinces Province[]

  organizations Organization[]
  stores        Store[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([code], map: "idx_country_code")
  @@index([nameTh], map: "idx_country_name_th")
  @@index([status], map: "idx_country_status")
  @@map("countries")
}

//////////////////////////////////////////////////////
// PROVINCE
//////////////////////////////////////////////////////

model Province {
  id String @id @default(uuid())

  countryId String @map("country_id")

  country Country @relation(fields: [countryId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  code   String
  nameTh String @map("name_th")
  nameEn String @map("name_en")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")

  districts District[]

  organizations Organization[]
  stores        Store[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([countryId, code], map: "uk_province_country_code")
  @@index([countryId], map: "idx_province_country")
  @@index([code], map: "idx_province_code")
  @@index([nameTh], map: "idx_province_name_th")
  @@index([status], map: "idx_province_status")
  @@map("provinces")
}

//////////////////////////////////////////////////////
// DISTRICT
//////////////////////////////////////////////////////

model District {
  id String @id @default(uuid())

  provinceId String @map("province_id")

  province Province @relation(fields: [provinceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  code   String
  nameTh String @map("name_th")
  nameEn String @map("name_en")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")

  subdistricts Subdistrict[]

  organizations Organization[]
  stores        Store[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([provinceId, code], map: "uk_district_province_code")
  @@index([provinceId], map: "idx_district_province")
  @@index([code], map: "idx_district_code")
  @@index([nameTh], map: "idx_district_name_th")
  @@index([status], map: "idx_district_status")
  @@map("districts")
}

//////////////////////////////////////////////////////
// SUBDISTRICT
//////////////////////////////////////////////////////

model Subdistrict {
  id String @id @default(uuid())

  districtId String @map("district_id")

  district District @relation(fields: [districtId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  code String

  nameTh String @map("name_th")
  nameEn String @map("name_en")

  postalCode String @map("postal_code")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")

  organizations Organization[]
  stores        Store[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([districtId, code], map: "uk_subdistrict_district_code")
  @@index([districtId], map: "idx_subdistrict_district")
  @@index([code], map: "idx_subdistrict_code")
  @@index([nameTh], map: "idx_subdistrict_name_th")
  @@index([status], map: "idx_subdistrict_status")
  @@map("subdistricts")
}

//////////////////////////////////////////////////////
// ORGANIZATION
//////////////////////////////////////////////////////

model Organization {
  id String @id @default(uuid())

  code String @unique
  name String
  slug String @unique

  taxId String? @map("tax_id")

  contactPerson String? @map("contact_person")
  phone1        String? @map("phone_1")
  phone2        String? @map("phone_2")
  email         String?

  address1 String?
  address2 String?
  remark   String?

  countryId     String  @map("country_id")
  provinceId    String? @map("province_id")
  districtId    String? @map("district_id")
  subdistrictId String? @map("subdistrict_id")

  country Country @relation(fields: [countryId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  province Province? @relation(fields: [provinceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  district District? @relation(fields: [districtId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  subdistrict Subdistrict? @relation(fields: [subdistrictId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  stores     Store[]
  categories ProductCategory[]
  brands     Brand[]
  units      Unit[]
  taxes      Tax[]
  products   Product[]
  attributes Attribute[]
  users      User[]
  roles      Role[]
  warehouses Warehouse[]

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  vendors          Vendor[]
  purchaseRequests PurchaseRequest[]
  purchaseOrders   PurchaseOrder[]

  orders          Order[]
  orderTags       OrderTag[]
  pickingWaves    PickingWave[]
  allocationRules AllocationRule[]
  shippingRules   ShippingRule[]
  automationRules AutomationRule[]

  customerGroups      CustomerGroup[]
  customers           Customer[]
  quotations          Quotation[]
  salesOrders         SalesOrder[]
  priceBooks          PriceBook[]
  salesChannels       SalesChannel[]
  marketplaceAccounts MarketplaceAccount[]
  AccountGroup        AccountGroup[]
  Account             Account[]
  FiscalYear          FiscalYear[]
  LedgerBook          LedgerBook[]
  ExchangeRate        ExchangeRate[]
  AccountingRule      AccountingRule[]
  JournalTemplate     JournalTemplate[]
  AccountMapping      AccountMapping[]
  Journal             Journal[]
  JournalEntry        JournalEntry[]
  AccountsReceivable  AccountsReceivable[]
  AccountsPayable     AccountsPayable[]
  CashAccount         CashAccount[]
  BankAccount         BankAccount[]
  TaxCode             TaxCode[]
  CostCenter          CostCenter[]
  ProfitCenter        ProfitCenter[]
  Budget              Budget[]
  Dashboard           Dashboard[]
  MetricDefinition    MetricDefinition[]
  KPI                 KPI[]
  KPIHistory          KPIHistory[]
  ReportTemplate      ReportTemplate[]
  AlertRule           AlertRule[]
  ForecastModel       ForecastModel[]
  Campaign            Campaign[]
  Promotion           Promotion[]
  VoucherBatch        VoucherBatch[]
  Voucher             Voucher[]
  ProductBundle       ProductBundle[]
  CustomerSegment     CustomerSegment[]
  PriceRule           PriceRule[]
  translations        Translation[]

  @@index([code], map: "idx_org_code")
  @@index([slug], map: "idx_org_slug")
  @@index([name], map: "idx_org_name")
  @@index([countryId], map: "idx_org_country")
  @@index([provinceId], map: "idx_org_province")
  @@index([districtId], map: "idx_org_district")
  @@index([subdistrictId], map: "idx_org_subdistrict")
  @@index([status], map: "idx_org_status")
  @@map("organizations")
}

//////////////////////////////////////////////////////
// STORE
//////////////////////////////////////////////////////

model Store {
  id String @id @default(uuid())

  organizationId String @map("organization_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  code String
  name String
  slug String

  taxId String? @map("tax_id")

  contactPerson String? @map("contact_person")
  phone1        String? @map("phone_1")
  phone2        String? @map("phone_2")
  email         String?

  address1 String?
  address2 String?
  remark   String?

  countryId     String  @map("country_id")
  provinceId    String? @map("province_id")
  districtId    String? @map("district_id")
  subdistrictId String? @map("subdistrict_id")

  country Country @relation(fields: [countryId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  province Province? @relation(fields: [provinceId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  district District? @relation(fields: [districtId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  subdistrict Subdistrict? @relation(fields: [subdistrictId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  defaultUsers User[]      @relation("DefaultStore")
  userStores   UserStore[]
  warehouses   Warehouse[]

  timezone String @default("Asia/Bangkok")
  currency String @default("THB")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchaseRequests PurchaseRequest[]
  purchaseOrders   PurchaseOrder[]

  orders Order[]

  quotations       Quotation[]
  salesOrders      SalesOrder[]
  marketplaceShops MarketplaceShop[]

  @@unique([organizationId, code], map: "uk_store_org_code")
  @@unique([organizationId, slug], map: "uk_store_org_slug")
  @@index([organizationId], map: "idx_store_org")
  @@index([code], map: "idx_store_code")
  @@index([slug], map: "idx_store_slug")
  @@index([name], map: "idx_store_name")
  @@index([countryId], map: "idx_store_country")
  @@index([provinceId], map: "idx_store_province")
  @@index([districtId], map: "idx_store_district")
  @@index([subdistrictId], map: "idx_store_subdistrict")
  @@index([status], map: "idx_store_status")
  @@map("stores")
}

//////////////////////////////////////////////////////
// PRODUCT CATEGORY
//////////////////////////////////////////////////////

model ProductCategory {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  parentId       String?      @map("parent_id")
  code           String
  name           String
  description    String?
  sortOrder      Int          @default(0) @map("sort_order")
  status         RecordStatus @default(ACTIVE)
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  parent       ProductCategory?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: Restrict)
  children     ProductCategory[] @relation("CategoryTree")
  products     Product[]
  priceRules   PriceRule[]

  @@unique([organizationId, code], map: "uk_category_org_code")
  @@index([organizationId])
  @@index([parentId])
  @@map("product_categories")
}

//////////////////////////////////////////////////////
// BRAND
//////////////////////////////////////////////////////

model Brand {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  code           String
  name           String
  logo           String?
  website        String?
  status         RecordStatus @default(ACTIVE)
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  products     Product[]

  @@unique([organizationId, code], map: "uk_brand_org_code")
  @@index([organizationId])
  @@map("brands")
}

//////////////////////////////////////////////////////
// UNIT
//////////////////////////////////////////////////////

model Unit {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  code           String
  name           String
  symbol         String
  status         RecordStatus @default(ACTIVE)
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  products             Product[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  goodsReceiveItems    GoodsReceiveItem[]
  purchaseReturnItems  PurchaseReturnItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]

  quotationItems    QuotationItem[]
  salesOrderItems   SalesOrderItem[]
  salesReturnItems  SalesReturnItem[]
  salesInvoiceItems SalesInvoiceItem[]

  @@unique([organizationId, code], map: "uk_unit_org_code")
  @@index([organizationId])
  @@map("units")
}

//////////////////////////////////////////////////////
// TAX
//////////////////////////////////////////////////////

model Tax {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  code           String
  name           String
  rate           Decimal      @db.Decimal(5, 2)
  status         RecordStatus @default(ACTIVE)
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  products     Product[]

  @@unique([organizationId, code], map: "uk_tax_org_code")
  @@index([organizationId])
  @@map("taxes")
}

//////////////////////////////////////////////////////
// PRODUCT
//////////////////////////////////////////////////////

model Product {
  id              String        @id @default(uuid())
  organizationId  String        @map("organization_id")
  categoryId      String        @map("category_id")
  brandId         String?       @map("brand_id")
  unitId          String        @map("unit_id")
  taxId           String?       @map("tax_id")
  code            String
  sku             String?
  name            String
  shortName       String?       @map("short_name")
  description     String?
  status          ProductStatus @default(DRAFT)
  isActive        Boolean       @default(true) @map("is_active")
  isSerialized    Boolean       @default(false) @map("is_serialized")
  allowBackorder  Boolean       @default(false) @map("allow_backorder")
  weight          Decimal?      @db.Decimal(10, 4)
  width           Decimal?      @db.Decimal(10, 4)
  height          Decimal?      @db.Decimal(10, 4)
  length          Decimal?      @db.Decimal(10, 4)
  slug            String
  metaTitle       String?       @map("meta_title")
  metaKeyword     String?       @map("meta_keyword")
  metaDescription String?       @map("meta_description")
  deletedAt       DateTime?     @map("deleted_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  category            ProductCategory      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  brand               Brand?               @relation(fields: [brandId], references: [id], onDelete: SetNull)
  unit                Unit                 @relation(fields: [unitId], references: [id], onDelete: Restrict)
  tax                 Tax?                 @relation(fields: [taxId], references: [id], onDelete: SetNull)
  variants            ProductVariant[]
  images              ProductImage[]
  marketplaceMappings ProductMarketplace[]
  marketplaceProducts MarketplaceProduct[]
  priceRules          PriceRule[]
  InventoryPolicy     InventoryPolicy?     @relation(fields: [inventoryPolicyId], references: [id])
  inventoryPolicyId   String?
  BundleItem          BundleItem[]

  @@unique([organizationId, code], map: "uk_product_org_code")
  @@unique([organizationId, slug], map: "uk_product_org_slug")
  @@index([organizationId])
  @@index([categoryId])
  @@index([brandId])
  @@index([unitId])
  @@index([taxId])
  @@map("products")
}

//////////////////////////////////////////////////////
// PRODUCT VARIANT
//////////////////////////////////////////////////////

model ProductVariant {
  id        String       @id @default(uuid())
  productId String       @map("product_id")
  sku       String
  name      String
  weight    Decimal?     @db.Decimal(10, 4)
  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  product              Product                        @relation(fields: [productId], references: [id], onDelete: Cascade)
  barcodes             ProductBarcode[]
  prices               ProductPrice[]
  attributeValues      ProductVariantAttributeValue[]
  marketplaceMappings  ProductMarketplace[]
  inventoryLocations   InventoryLocation[]
  movements            InventoryMovement[]
  adjustmentItems      StockAdjustmentItem[]
  transferItems        StockTransferItem[]
  snapshots            InventorySnapshot[]
  vendorPrices         VendorPriceList[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  goodsReceiveItems    GoodsReceiveItem[]
  purchaseReturnItems  PurchaseReturnItem[]
  purchaseInvoiceItems PurchaseInvoiceItem[]

  quotationItems         QuotationItem[]
  salesOrderItems        SalesOrderItem[]
  salesReturnItems       SalesReturnItem[]
  salesInvoiceItems      SalesInvoiceItem[]
  priceBookItems         PriceBookItem[]
  marketplaceVariants    MarketplaceVariant[]
  marketplaceInventories MarketplaceInventory[]
  marketplaceOrderItems  MarketplaceOrderItem[]

  orderItems       OrderItem[]
  allocationItems  AllocationItem[]
  fulfillmentItems FulfillmentItem[]
  backOrders       BackOrder[]
  lots             InventoryLot[]
  serials          InventorySerial[]
  ReceivingItem    ReceivingItem[]
  PutAwayItem      PutAwayItem[]
  PickingTaskItem  PickingTaskItem[]
  PackingTaskItem  PackingTaskItem[]
  CycleCountItem   CycleCountItem[]

  @@unique([productId, sku], map: "uk_variant_product_sku")
  @@index([productId])
  @@map("product_variants")
}

//////////////////////////////////////////////////////
// PRODUCT BARCODE
//////////////////////////////////////////////////////

model ProductBarcode {
  id        String   @id @default(uuid())
  variantId String   @map("variant_id")
  barcode   String
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([variantId, barcode], map: "uk_barcode_variant_code")
  @@index([variantId])
  @@map("product_barcodes")
}

//////////////////////////////////////////////////////
// PRODUCT PRICE
//////////////////////////////////////////////////////

model ProductPrice {
  id        String    @id @default(uuid())
  variantId String    @map("variant_id")
  priceType String    @map("price_type") // Retail, Wholesale, Member, VIP, Marketplace
  currency  String    @default("THB")
  price     Decimal   @db.Decimal(12, 2)
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@map("product_prices")
}

//////////////////////////////////////////////////////
// PRODUCT IMAGE
//////////////////////////////////////////////////////

model ProductImage {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  altText   String?  @map("alt_text")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_images")
}

//////////////////////////////////////////////////////
// ATTRIBUTES
//////////////////////////////////////////////////////

model Attribute {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  values       AttributeValue[]

  @@unique([organizationId, name], map: "uk_attribute_org_name")
  @@index([organizationId])
  @@map("attributes")
}

model AttributeValue {
  id          String   @id @default(uuid())
  attributeId String   @map("attribute_id")
  value       String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  attribute        Attribute                      @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  variantRelations ProductVariantAttributeValue[]

  @@unique([attributeId, value], map: "uk_attr_value_name")
  @@index([attributeId])
  @@map("attribute_values")
}

model ProductVariantAttributeValue {
  id               String   @id @default(uuid())
  variantId        String   @map("variant_id")
  attributeValueId String   @map("attribute_value_id")
  createdAt        DateTime @default(now()) @map("created_at")

  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValue AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeValueId], map: "uk_variant_attr_value")
  @@index([variantId])
  @@index([attributeValueId])
  @@map("product_variant_attribute_values")
}

//////////////////////////////////////////////////////
// PRODUCT MARKETPLACE
//////////////////////////////////////////////////////

model ProductMarketplace {
  id                String          @id @default(uuid())
  productId         String?         @map("product_id")
  variantId         String?         @map("variant_id")
  marketplace       MarketplaceType
  externalProductId String          @map("external_product_id")
  externalVariantId String?         @map("external_variant_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")

  product Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([variantId])
  @@map("product_marketplaces")
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  defaultStoreId String?      @map("default_store_id")
  username       String
  email          String
  phone          String?
  passwordHash   String       @map("password_hash")
  firstName      String?      @map("first_name")
  lastName       String?      @map("last_name")
  displayName    String?      @map("display_name")
  avatar         String?
  lastLoginAt    DateTime?    @map("last_login_at")
  status         RecordStatus @default(ACTIVE)
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization       Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  defaultStore       Store?              @relation("DefaultStore", fields: [defaultStoreId], references: [id], onDelete: SetNull)
  userRoles          UserRole[]
  userStores         UserStore[]
  refreshTokens      RefreshToken[]
  sessions           UserSession[]
  loginHistories     LoginHistory[]
  auditLogs          AuditLog[]
  adjustmentsCreated StockAdjustment[]
  transfersCreated   StockTransfer[]
  movementsCreated   InventoryMovement[]

  orderStatusHistories OrderStatusHistory[]
  fulfillments         Fulfillment[]
  orderNotes           OrderNote[]
  PutAway              PutAway[]
  PickingTask          PickingTask[]
  PackingTask          PackingTask[]
  CycleCount           CycleCount[]

  @@unique([organizationId, username], map: "uk_user_org_username")
  @@unique([organizationId, email], map: "uk_user_org_email")
  @@index([organizationId])
  @@index([defaultStoreId])
  @@map("users")
}

//////////////////////////////////////////////////////
// ROLE
//////////////////////////////////////////////////////

model Role {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  code           String
  name           String
  description    String?
  isSystem       Boolean      @default(false) @map("is_system")
  status         RecordStatus @default(ACTIVE)
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@unique([organizationId, code], map: "uk_role_org_code")
  @@index([organizationId])
  @@map("roles")
}

//////////////////////////////////////////////////////
// PERMISSION
//////////////////////////////////////////////////////

model Permission {
  id              String           @id @default(uuid())
  code            String           @unique
  module          String
  name            String
  description     String?
  rolePermissions RolePermission[]

  @@map("permissions")
}

//////////////////////////////////////////////////////
// USER ROLE
//////////////////////////////////////////////////////

model UserRole {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId], map: "uk_user_role_user_role")
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

//////////////////////////////////////////////////////
// ROLE PERMISSION
//////////////////////////////////////////////////////

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String   @map("role_id")
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], map: "uk_role_permission_role_perm")
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

//////////////////////////////////////////////////////
// USER STORE
//////////////////////////////////////////////////////

model UserStore {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  storeId   String   @map("store_id")
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId], map: "uk_user_store_user_store")
  @@index([userId])
  @@index([storeId])
  @@map("user_stores")
}

//////////////////////////////////////////////////////
// REFRESH TOKEN
//////////////////////////////////////////////////////

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  token     String    @unique
  expiredAt DateTime  @map("expired_at")
  revokedAt DateTime? @map("revoked_at")
  ip        String?
  userAgent String?   @map("user_agent")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

//////////////////////////////////////////////////////
// USER SESSION
//////////////////////////////////////////////////////

model UserSession {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  token        String   @unique
  ip           String?
  userAgent    String?  @map("user_agent")
  device       String?
  browser      String?
  lastActiveAt DateTime @default(now()) @map("last_active_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

//////////////////////////////////////////////////////
// LOGIN HISTORY
//////////////////////////////////////////////////////

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  ip        String?
  browser   String?
  device    String?
  success   Boolean
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("login_histories")
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String
  module    String
  recordId  String   @map("record_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@map("audit_logs")
}

//////////////////////////////////////////////////////
// WAREHOUSE
//////////////////////////////////////////////////////

model Warehouse {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  storeId        String       @map("store_id")
  code           String
  name           String
  description    String?
  isDefault      Boolean      @default(false) @map("is_default")
  status         RecordStatus @default(ACTIVE)
  deletedAt      DateTime?    @map("deleted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization  Organization        @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store         Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  locations     WarehouseLocation[]
  zones         WarehouseZone[]
  fromTransfers StockTransfer[]     @relation("FromWarehouse")
  toTransfers   StockTransfer[]     @relation("ToWarehouse")
  adjustments   StockAdjustment[]
  snapshots     InventorySnapshot[]

  purchaseOrders PurchaseOrder[]
  goodsReceives  GoodsReceive[]

  salesOrders  SalesOrder[]
  allocations  Allocation[]
  pickingWaves PickingWave[]
  Receiving    Receiving[]
  PickingTask  PickingTask[]
  CycleCount   CycleCount[]

  @@unique([organizationId, code], map: "uk_warehouse_org_code")
  @@index([organizationId])
  @@index([storeId])
  @@map("warehouses")
}

//////////////////////////////////////////////////////

//////////////////////////////////////////////////////

//////////////////////////////////////////////////////

//////////////////////////////////////////////////////

//////////////////////////////////////////////////////

//////////////////////////////////////////////////////
// STOCK ADJUSTMENT
//////////////////////////////////////////////////////

model StockAdjustment {
  id          String   @id @default(uuid())
  warehouseId String   @map("warehouse_id")
  reason      String?
  status      String   @default("DRAFT")
  createdBy   String?  @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  warehouse Warehouse             @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  creator   User?                 @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  items     StockAdjustmentItem[]

  @@index([warehouseId])
  @@index([createdBy])
  @@map("stock_adjustments")
}

//////////////////////////////////////////////////////
// STOCK ADJUSTMENT ITEM
//////////////////////////////////////////////////////

model StockAdjustmentItem {
  id                  String  @id @default(uuid())
  adjustmentId        String  @map("adjustment_id")
  variantId           String  @map("variant_id")
  warehouseLocationId String  @map("warehouse_location_id")
  lotId               String? @map("lot_id")
  serialId            String? @map("serial_id")
  beforeQty           Int     @map("before_qty")
  afterQty            Int     @map("after_qty")
  difference          Int
  reason              String?

  adjustment StockAdjustment   @relation(fields: [adjustmentId], references: [id], onDelete: Cascade)
  variant    ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  location   WarehouseLocation @relation(fields: [warehouseLocationId], references: [id], onDelete: Restrict)
  lot        InventoryLot?     @relation(fields: [lotId], references: [id])
  serial     InventorySerial?  @relation(fields: [serialId], references: [id])

  @@index([adjustmentId])
  @@index([variantId])
  @@index([warehouseLocationId])
  @@map("stock_adjustment_items")
}

//////////////////////////////////////////////////////
// STOCK TRANSFER
//////////////////////////////////////////////////////

model StockTransfer {
  id              String   @id @default(uuid())
  fromWarehouseId String   @map("from_warehouse_id")
  toWarehouseId   String   @map("to_warehouse_id")
  status          String   @default("DRAFT")
  transferDate    DateTime @default(now()) @map("transfer_date")
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  fromWarehouse Warehouse           @relation("FromWarehouse", fields: [fromWarehouseId], references: [id], onDelete: Restrict)
  toWarehouse   Warehouse           @relation("ToWarehouse", fields: [toWarehouseId], references: [id], onDelete: Restrict)
  creator       User?               @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  items         StockTransferItem[]

  @@index([fromWarehouseId])
  @@index([toWarehouseId])
  @@index([createdBy])
  @@map("stock_transfers")
}

//////////////////////////////////////////////////////
// STOCK TRANSFER ITEM
//////////////////////////////////////////////////////

model StockTransferItem {
  id             String @id @default(uuid())
  transferId     String @map("transfer_id")
  variantId      String @map("variant_id")
  fromLocationId String @map("from_location_id")
  toLocationId   String @map("to_location_id")
  quantity       Int

  transfer     StockTransfer     @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variant      ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  fromLocation WarehouseLocation @relation("TransferFromLocation", fields: [fromLocationId], references: [id], onDelete: Restrict)
  toLocation   WarehouseLocation @relation("TransferToLocation", fields: [toLocationId], references: [id], onDelete: Restrict)

  @@index([transferId])
  @@index([variantId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@map("stock_transfer_items")
}

//////////////////////////////////////////////////////
// INVENTORY SNAPSHOT
//////////////////////////////////////////////////////

model InventorySnapshot {
  id           String   @id @default(uuid())
  snapshotDate DateTime @map("snapshot_date")
  warehouseId  String   @map("warehouse_id")
  variantId    String   @map("variant_id")
  quantity     Int

  warehouse Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([snapshotDate, warehouseId, variantId], map: "uk_inventory_snapshot")
  @@index([warehouseId])
  @@index([variantId])
  @@map("inventory_snapshots")
}

//////////////////////////////////////////////////////
// SPRINT 5: PURCHASE MANAGEMENT
//////////////////////////////////////////////////////

model Vendor {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  code           String
  name           String
  taxId          String?  @map("tax_id")
  branch         String?
  contactPerson  String?  @map("contact_person")
  phone1         String?  @map("phone_1")
  phone2         String?  @map("phone_2")
  email          String?
  website        String?
  creditDays     Int      @default(0) @map("credit_days")
  creditLimit    Decimal? @map("credit_limit") @db.Decimal(18, 4)
  paymentTerm    String?  @map("payment_term")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  addresses       VendorAddress[]
  contacts        VendorContact[]
  priceLists      VendorPriceList[]
  purchaseOrders  PurchaseOrder[]
  invoices        PurchaseInvoice[]
  returns         PurchaseReturn[]
  AccountsPayable AccountsPayable[]

  @@unique([organizationId, code], map: "uk_vendor_org_code")
  @@index([organizationId])
  @@index([name])
  @@map("vendors")
}

model VendorAddress {
  id            String  @id @default(uuid())
  vendorId      String  @map("vendor_id")
  type          String // e.g., HQ, BILLING, WAREHOUSE
  address1      String
  address2      String?
  countryId     String? @map("country_id")
  provinceId    String? @map("province_id")
  districtId    String? @map("district_id")
  subdistrictId String? @map("subdistrict_id")
  isDefault     Boolean @default(false) @map("is_default")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_addresses")
}

model VendorContact {
  id        String  @id @default(uuid())
  vendorId  String  @map("vendor_id")
  name      String
  position  String?
  phone     String?
  email     String?
  isPrimary Boolean @default(false) @map("is_primary")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_contacts")
}

model VendorPriceList {
  id            String    @id @default(uuid())
  vendorId      String    @map("vendor_id")
  variantId     String    @map("variant_id")
  price         Decimal   @db.Decimal(18, 4)
  currency      String    @default("THB")
  minQuantity   Int       @default(1) @map("min_quantity")
  effectiveDate DateTime  @default(now()) @map("effective_date")
  expiryDate    DateTime? @map("expiry_date")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  vendor  Vendor         @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([variantId])
  @@map("vendor_price_lists")
}

model PurchaseRequest {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  storeId        String   @map("store_id")
  requestNo      String   @map("request_no")
  requestDate    DateTime @default(now()) @map("request_date")
  requestBy      String   @map("request_by")
  status         String   @default("DRAFT") // DRAFT, WAITING_APPROVAL, APPROVED, REJECTED, PO_CREATED, CANCELLED
  remark         String?

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store          Store                 @relation(fields: [storeId], references: [id], onDelete: Restrict)
  items          PurchaseRequestItem[]
  purchaseOrders PurchaseOrder[]

  @@unique([organizationId, requestNo], map: "uk_pr_org_no")
  @@index([organizationId])
  @@index([storeId])
  @@map("purchase_requests")
}

model PurchaseRequestItem {
  id                String  @id @default(uuid())
  purchaseRequestId String  @map("purchase_request_id")
  variantId         String  @map("variant_id")
  quantity          Int
  unitId            String  @map("unit_id")
  remark            String?

  purchaseRequest PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  variant         ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)
  unit            Unit            @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([purchaseRequestId])
  @@index([variantId])
  @@map("purchase_request_items")
}

model PurchaseOrder {
  id                String  @id @default(uuid())
  organizationId    String  @map("organization_id")
  storeId           String  @map("store_id")
  warehouseId       String  @map("warehouse_id")
  vendorId          String  @map("vendor_id")
  purchaseRequestId String? @map("purchase_request_id")

  purchaseNo   String    @map("purchase_no")
  purchaseDate DateTime  @default(now()) @map("purchase_date")
  expectedDate DateTime? @map("expected_date")
  currency     String    @default("THB")
  exchangeRate Decimal   @default(1.0) @map("exchange_rate") @db.Decimal(18, 4)

  subtotal     Decimal @default(0) @db.Decimal(18, 4)
  discount     Decimal @default(0) @db.Decimal(18, 4)
  vat          Decimal @default(0) @db.Decimal(18, 4)
  shippingCost Decimal @default(0) @map("shipping_cost") @db.Decimal(18, 4)
  grandTotal   Decimal @default(0) @map("grand_total") @db.Decimal(18, 4)

  status String  @default("DRAFT") // DRAFT, WAITING_APPROVAL, APPROVED, PARTIALLY_RECEIVED, COMPLETED, CANCELLED
  remark String?

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store           Store            @relation(fields: [storeId], references: [id], onDelete: Restrict)
  warehouse       Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  vendor          Vendor           @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  purchaseRequest PurchaseRequest? @relation(fields: [purchaseRequestId], references: [id], onDelete: SetNull)

  items         PurchaseOrderItem[]
  goodsReceives GoodsReceive[]
  invoices      PurchaseInvoice[]

  @@unique([organizationId, purchaseNo], map: "uk_po_org_no")
  @@index([organizationId])
  @@index([storeId])
  @@index([warehouseId])
  @@index([vendorId])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String  @id @default(uuid())
  purchaseOrderId String  @map("purchase_order_id")
  variantId       String  @map("variant_id")
  unitId          String  @map("unit_id")
  description     String?

  quantity    Int
  receivedQty Int     @default(0) @map("received_qty")
  unitPrice   Decimal @default(0) @map("unit_price") @db.Decimal(18, 4)
  discount    Decimal @default(0) @db.Decimal(18, 4)
  taxRate     Decimal @default(0) @map("tax_rate") @db.Decimal(18, 4)
  lineTotal   Decimal @default(0) @map("line_total") @db.Decimal(18, 4)

  status String @default("PENDING") // PENDING, PARTIALLY_RECEIVED, RECEIVED

  purchaseOrder PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  unit          Unit           @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([purchaseOrderId])
  @@index([variantId])
  @@map("purchase_order_items")
}

model GoodsReceive {
  id              String   @id @default(uuid())
  purchaseOrderId String   @map("purchase_order_id")
  warehouseId     String   @map("warehouse_id")
  receiveNo       String   @map("receive_no")
  receiveDate     DateTime @default(now()) @map("receive_date")
  receivedBy      String   @map("received_by")
  status          String   @default("DRAFT") // DRAFT, QC_PENDING, COMPLETED, CANCELLED
  remark          String?

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  items         GoodsReceiveItem[]
  Receiving     Receiving[]

  @@unique([warehouseId, receiveNo], map: "uk_gr_wh_no")
  @@index([purchaseOrderId])
  @@index([warehouseId])
  @@map("goods_receives")
}

model GoodsReceiveItem {
  id                  String  @id @default(uuid())
  goodsReceiveId      String  @map("goods_receive_id")
  purchaseOrderItemId String? @map("purchase_order_item_id")
  variantId           String  @map("variant_id")
  unitId              String  @map("unit_id")
  locationId          String  @map("location_id")
  lotNumber           String? @map("lot_number")
  serialNumber        String? @map("serial_number")
  quantity            Int

  status String @default("PENDING")

  goodsReceive GoodsReceive      @relation(fields: [goodsReceiveId], references: [id], onDelete: Cascade)
  variant      ProductVariant    @relation(fields: [variantId], references: [id], onDelete: Restrict)
  unit         Unit              @relation(fields: [unitId], references: [id], onDelete: Restrict)
  location     WarehouseLocation @relation(fields: [locationId], references: [id], onDelete: Restrict)

  @@index([goodsReceiveId])
  @@index([variantId])
  @@index([locationId])
  @@map("goods_receive_items")
}

model PurchaseInvoice {
  id              String    @id @default(uuid())
  vendorId        String    @map("vendor_id")
  purchaseOrderId String?   @map("purchase_order_id")
  invoiceNo       String    @map("invoice_no")
  invoiceDate     DateTime  @map("invoice_date")
  dueDate         DateTime? @map("due_date")

  subtotal   Decimal @default(0) @db.Decimal(18, 4)
  vat        Decimal @default(0) @db.Decimal(18, 4)
  grandTotal Decimal @default(0) @map("grand_total") @db.Decimal(18, 4)

  status String @default("PENDING") // PENDING, PAID, PARTIALLY_PAID, CANCELLED

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  vendor          Vendor                @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  purchaseOrder   PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  items           PurchaseInvoiceItem[]
  payments        PurchasePayment[]
  AccountsPayable AccountsPayable[]

  @@unique([vendorId, invoiceNo], map: "uk_inv_vendor_no")
  @@index([vendorId])
  @@index([purchaseOrderId])
  @@map("purchase_invoices")
}

model PurchaseInvoiceItem {
  id                String  @id @default(uuid())
  purchaseInvoiceId String  @map("purchase_invoice_id")
  variantId         String  @map("variant_id")
  unitId            String  @map("unit_id")
  description       String?
  quantity          Int
  unitPrice         Decimal @default(0) @map("unit_price") @db.Decimal(18, 4)
  lineTotal         Decimal @default(0) @map("line_total") @db.Decimal(18, 4)

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)
  variant         ProductVariant  @relation(fields: [variantId], references: [id], onDelete: Restrict)
  unit            Unit            @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([purchaseInvoiceId])
  @@index([variantId])
  @@map("purchase_invoice_items")
}

model PurchasePayment {
  id                String   @id @default(uuid())
  purchaseInvoiceId String   @map("purchase_invoice_id")
  paymentDate       DateTime @default(now()) @map("payment_date")
  paymentMethod     String   @map("payment_method") // CASH, BANK, CHEQUE, TRANSFER
  amount            Decimal  @db.Decimal(18, 4)
  reference         String?

  status String @default("COMPLETED") // PENDING, COMPLETED, CANCELLED

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  purchaseInvoice PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Restrict)

  @@index([purchaseInvoiceId])
  @@map("purchase_payments")
}

model PurchaseReturn {
  id         String   @id @default(uuid())
  vendorId   String   @map("vendor_id")
  returnNo   String   @map("return_no")
  returnDate DateTime @default(now()) @map("return_date")
  reason     String?
  status     String   @default("DRAFT") // DRAFT, COMPLETED, CANCELLED

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  vendor Vendor               @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  items  PurchaseReturnItem[]

  @@unique([vendorId, returnNo], map: "uk_ret_vendor_no")
  @@index([vendorId])
  @@map("purchase_returns")
}

model PurchaseReturnItem {
  id               String  @id @default(uuid())
  purchaseReturnId String  @map("purchase_return_id")
  variantId        String  @map("variant_id")
  unitId           String  @map("unit_id")
  quantity         Int
  reason           String?

  purchaseReturn PurchaseReturn @relation(fields: [purchaseReturnId], references: [id], onDelete: Cascade)
  variant        ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  unit           Unit           @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([purchaseReturnId])
  @@index([variantId])
  @@map("purchase_return_items")
}

//////////////////////////////////////////////////////
// SPRINT 6: SALES MANAGEMENT
//////////////////////////////////////////////////////

model CustomerGroup {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  code           String
  name           String
  description    String?

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customers    Customer[]
  priceBooks   PriceBook[]

  @@unique([organizationId, code], map: "uk_customer_group_org_code")
  @@index([organizationId])
  @@map("customer_groups")
}

model Customer {
  id              String   @id @default(uuid())
  organizationId  String   @map("organization_id")
  customerGroupId String?  @map("customer_group_id")
  code            String
  name            String
  taxId           String?  @map("tax_id")
  branch          String?
  contactPerson   String?  @map("contact_person")
  phone1          String?  @map("phone_1")
  phone2          String?  @map("phone_2")
  email           String?
  creditDays      Int      @default(0) @map("credit_days")
  creditLimit     Decimal? @map("credit_limit") @db.Decimal(18, 4)

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization       Organization         @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customerGroup      CustomerGroup?       @relation(fields: [customerGroupId], references: [id], onDelete: SetNull)
  addresses          CustomerAddress[]
  contacts           CustomerContact[]
  quotations         Quotation[]
  orders             Order[]
  salesOrders        SalesOrder[]
  AccountsReceivable AccountsReceivable[]
  Voucher            Voucher[]
  VoucherUsage       VoucherUsage[]

  @@unique([organizationId, code], map: "uk_customer_org_code")
  @@index([organizationId])
  @@index([name])
  @@map("customers")
}

model CustomerAddress {
  id            String  @id @default(uuid())
  customerId    String  @map("customer_id")
  type          String // e.g., HQ, BILLING, SHIPPING
  address1      String
  address2      String?
  countryId     String? @map("country_id")
  provinceId    String? @map("province_id")
  districtId    String? @map("district_id")
  subdistrictId String? @map("subdistrict_id")
  isDefault     Boolean @default(false) @map("is_default")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_addresses")
}

model CustomerContact {
  id         String  @id @default(uuid())
  customerId String  @map("customer_id")
  name       String
  position   String?
  phone      String?
  email      String?
  isPrimary  Boolean @default(false) @map("is_primary")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("customer_contacts")
}

model PriceBook {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  customerGroupId String?   @map("customer_group_id")
  code            String
  name            String
  description     String?
  currency        String    @default("THB")
  effectiveDate   DateTime  @default(now()) @map("effective_date")
  expiryDate      DateTime? @map("expiry_date")

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization  Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customerGroup CustomerGroup?  @relation(fields: [customerGroupId], references: [id], onDelete: SetNull)
  items         PriceBookItem[]

  @@unique([organizationId, code], map: "uk_price_book_org_code")
  @@index([organizationId])
  @@map("price_books")
}

model PriceBookItem {
  id          String  @id @default(uuid())
  priceBookId String  @map("price_book_id")
  variantId   String  @map("variant_id")
  price       Decimal @db.Decimal(18, 4)
  minQuantity Int     @default(1) @map("min_quantity")

  priceBook PriceBook      @relation(fields: [priceBookId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@unique([priceBookId, variantId, minQuantity], map: "uk_price_book_item")
  @@index([variantId])
  @@map("price_book_items")
}

model SalesChannel {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  code           String
  name           String // e.g., POS, Shopee, Lazada, B2B

  status    RecordStatus @default(ACTIVE)
  deletedAt DateTime?    @map("deleted_at")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  salesOrders  SalesOrder[]

  @@unique([organizationId, code], map: "uk_sales_channel_org_code")
  @@index([organizationId])
  @@map("sales_channels")
}

model Quotation {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  storeId        String @map("store_id")
  customerId     String @map("customer_id")

  quotationNo   String    @map("quotation_no")
  quotationDate DateTime  @default(now()) @map("quotation_date")
  expireDate    DateTime? @map("expire_date")

  subtotal   Decimal @default(0) @db.Decimal(18, 4)
  discount   Decimal @default(0) @db.Decimal(18, 4)
  vat        Decimal @default(0) @db.Decimal(18, 4)
  grandTotal Decimal @default(0) @map("grand_total") @db.Decimal(18, 4)

  status String  @default("DRAFT") // DRAFT, SENT, ACCEPTED, REJECTED, EXPIRED
  remark String?

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Restrict)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)

  items       QuotationItem[]
  salesOrders SalesOrder[]

  @@unique([organizationId, quotationNo], map: "uk_quotation_org_no")
  @@index([organizationId])
  @@index([storeId])
  @@index([customerId])
  @@map("quotations")
}

model QuotationItem {
  id          String @id @default(uuid())
  quotationId String @map("quotation_id")
  variantId   String @map("variant_id")
  unitId      String @map("unit_id")

  quantity  Int
  unitPrice Decimal @default(0) @map("unit_price") @db.Decimal(18, 4)
  discount  Decimal @default(0) @db.Decimal(18, 4)
  taxRate   Decimal @default(0) @map("tax_rate") @db.Decimal(18, 4)
  lineTotal Decimal @default(0) @map("line_total") @db.Decimal(18, 4)

  quotation Quotation      @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  unit      Unit           @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([quotationId])
  @@index([variantId])
  @@map("quotation_items")
}

model SalesOrder {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  storeId        String  @map("store_id")
  warehouseId    String? @map("warehouse_id")
  customerId     String  @map("customer_id")
  channelId      String? @map("channel_id")
  quotationId    String? @map("quotation_id")
  omsOrderId     String? @map("oms_order_id")

  orderNo      String   @map("order_no")
  orderDate    DateTime @default(now()) @map("order_date")
  currency     String   @default("THB")
  exchangeRate Decimal  @default(1.0) @map("exchange_rate") @db.Decimal(18, 4)

  promotionCode String? @map("promotion_code")

  subtotal    Decimal @default(0) @db.Decimal(18, 4)
  discount    Decimal @default(0) @db.Decimal(18, 4)
  vat         Decimal @default(0) @db.Decimal(18, 4)
  shippingFee Decimal @default(0) @map("shipping_fee") @db.Decimal(18, 4)
  grandTotal  Decimal @default(0) @map("grand_total") @db.Decimal(18, 4)

  status String  @default("DRAFT") // DRAFT, CONFIRMED, RESERVED, PICKING, PACKING, SHIPPED, COMPLETED, BACKORDERED, CANCELLED
  remark String?

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  store        Store         @relation(fields: [storeId], references: [id], onDelete: Restrict)
  warehouse    Warehouse?    @relation(fields: [warehouseId], references: [id], onDelete: Restrict)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  channel      SalesChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  quotation    Quotation?    @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  omsOrder     Order?        @relation(fields: [omsOrderId], references: [id], onDelete: SetNull)

  items             SalesOrderItem[]
  shipments         Shipment[]
  invoices          SalesInvoice[]
  returns           SalesReturn[]
  marketplaceOrders MarketplaceOrder[]

  @@unique([organizationId, orderNo], map: "uk_so_org_no")
  @@index([organizationId])
  @@index([storeId])
  @@index([customerId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id           String @id @default(uuid())
  salesOrderId String @map("sales_order_id")
  variantId    String @map("variant_id")
  unitId       String @map("unit_id")

  quantity    Int
  reservedQty Int @default(0) @map("reserved_qty")
  shippedQty  Int @default(0) @map("shipped_qty")

  unitPrice Decimal @default(0) @map("unit_price") @db.Decimal(18, 4)
  discount  Decimal @default(0) @db.Decimal(18, 4)
  taxRate   Decimal @default(0) @map("tax_rate") @db.Decimal(18, 4)
  lineTotal Decimal @default(0) @map("line_total") @db.Decimal(18, 4)

  salesOrder    SalesOrder     @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  variant       ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  unit          Unit           @relation(fields: [unitId], references: [id], onDelete: Restrict)
  shipmentItems ShipmentItem[]

  @@index([salesOrderId])
  @@index([variantId])
  @@map("sales_order_items")
}

model Shipment {
  id           String   @id @default(uuid())
  salesOrderId String   @map("sales_order_id")
  shipmentNo   String   @map("shipment_no")
  carrier      String?
  trackingNo   String?  @map("tracking_no")
  shipDate     DateTime @default(now()) @map("ship_date")
  status       String   @default("PENDING") // PENDING, SHIPPED, DELIVERED, CANCELLED

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  salesOrder           SalesOrder            @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  items                ShipmentItem[]
  marketplaceShipments MarketplaceShipment[]
  shipmentLabels       ShipmentLabel[]

  @@unique([shipmentNo], map: "uk_shipment_no")
  @@index([salesOrderId])
  @@map("shipments")
}

model ShipmentItem {
  id               String @id @default(uuid())
  shipmentId       String @map("shipment_id")
  salesOrderItemId String @map("sales_order_item_id")
  quantity         Int

  shipment       Shipment       @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  salesOrderItem SalesOrderItem @relation(fields: [salesOrderItemId], references: [id], onDelete: Restrict)

  @@index([shipmentId])
  @@index([salesOrderItemId])
  @@map("shipment_items")
}

model SalesInvoice {
  id           String   @id @default(uuid())
  salesOrderId String   @map("sales_order_id")
  invoiceNo    String   @map("invoice_no")
  invoiceDate  DateTime @default(now()) @map("invoice_date")

  subtotal   Decimal @default(0) @db.Decimal(18, 4)
  vat        Decimal @default(0) @db.Decimal(18, 4)
  grandTotal Decimal @default(0) @map("grand_total") @db.Decimal(18, 4)

  status String @default("PENDING") // PENDING, PAID, CANCELLED

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  salesOrder         SalesOrder           @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  items              SalesInvoiceItem[]
  receipts           Receipt[]
  creditNotes        CreditNote[]
  AccountsReceivable AccountsReceivable[]

  @@unique([invoiceNo], map: "uk_sales_invoice_no")
  @@index([salesOrderId])
  @@map("sales_invoices")
}

model SalesInvoiceItem {
  id             String @id @default(uuid())
  salesInvoiceId String @map("sales_invoice_id")
  variantId      String @map("variant_id")
  unitId         String @map("unit_id")

  quantity  Int
  unitPrice Decimal @default(0) @map("unit_price") @db.Decimal(18, 4)
  lineTotal Decimal @default(0) @map("line_total") @db.Decimal(18, 4)

  salesInvoice SalesInvoice   @relation(fields: [salesInvoiceId], references: [id], onDelete: Cascade)
  variant      ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  unit         Unit           @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([salesInvoiceId])
  @@index([variantId])
  @@map("sales_invoice_items")
}

model Receipt {
  id             String   @id @default(uuid())
  salesInvoiceId String   @map("sales_invoice_id")
  receiptNo      String   @map("receipt_no")
  paymentMethod  String   @map("payment_method") // CASH, TRANSFER, PROMPTPAY, CREDIT_CARD
  paymentDate    DateTime @default(now()) @map("payment_date")
  amount         Decimal  @db.Decimal(18, 4)
  reference      String?

  status String @default("COMPLETED")

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Restrict)

  @@unique([receiptNo], map: "uk_receipt_no")
  @@index([salesInvoiceId])
  @@map("receipts")
}

model SalesReturn {
  id           String   @id @default(uuid())
  salesOrderId String   @map("sales_order_id")
  returnNo     String   @map("return_no")
  returnDate   DateTime @default(now()) @map("return_date")
  reason       String?
  status       String   @default("COMPLETED") // COMPLETED, CANCELLED

  deletedAt DateTime? @map("deleted_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  salesOrder SalesOrder        @relation(fields: [salesOrderId], references: [id], onDelete: Restrict)
  items      SalesReturnItem[]

  @@unique([returnNo], map: "uk_sales_return_no")
  @@index([salesOrderId])
  @@map("sales_returns")
}

model SalesReturnItem {
  id            String  @id @default(uuid())
  salesReturnId String  @map("sales_return_id")
  variantId     String  @map("variant_id")
  unitId        String  @map("unit_id")
  quantity      Int
  reason        String?

  salesReturn SalesReturn    @relation(fields: [salesReturnId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Restrict)
  unit        Unit           @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([salesReturnId])
  @@index([variantId])
  @@map("sales_return_items")
}

model CreditNote {
  id             String  @id @default(uuid())
  salesInvoiceId String  @map("sales_invoice_id")
  creditNo       String  @map("credit_no")
  amount         Decimal @db.Decimal(18, 4)
  reason         String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  salesInvoice SalesInvoice @relation(fields: [salesInvoiceId], references: [id], onDelete: Restrict)

  @@unique([creditNo], map: "uk_credit_note_no")
  @@index([salesInvoiceId])
  @@map("credit_notes")
}

//////////////////////////////////////////////////////
// SPRINT 7: MARKETPLACE INTEGRATION
//////////////////////////////////////////////////////

model Marketplace {
  id         String       @id @default(uuid())
  code       String       @unique
  name       String
  apiVersion String?      @map("api_version")
  baseUrl    String?      @map("base_url")
  status     RecordStatus @default(ACTIVE)

  accounts MarketplaceAccount[]
  webhooks MarketplaceWebhook[]

  @@map("marketplaces")
}

model MarketplaceAccount {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  marketplaceId  String       @map("marketplace_id")
  name           String
  status         RecordStatus @default(ACTIVE)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  marketplace  Marketplace  @relation(fields: [marketplaceId], references: [id], onDelete: Restrict)

  shops  MarketplaceShop[]
  tokens MarketplaceToken[]

  @@index([organizationId])
  @@index([marketplaceId])
  @@map("marketplace_accounts")
}

model MarketplaceShop {
  id        String       @id @default(uuid())
  accountId String       @map("account_id")
  storeId   String       @map("store_id")
  shopId    String       @map("shop_id")
  shopName  String       @map("shop_name")
  country   String?
  currency  String?
  status    RecordStatus @default(ACTIVE)

  account MarketplaceAccount @relation(fields: [accountId], references: [id], onDelete: Restrict)
  store   Store              @relation(fields: [storeId], references: [id], onDelete: Restrict)

  products    MarketplaceProduct[]
  inventories MarketplaceInventory[]
  orders      MarketplaceOrder[]
  errorLogs   MarketplaceErrorLog[]

  @@index([accountId])
  @@index([storeId])
  @@map("marketplace_shops")
}

model MarketplaceToken {
  id           String   @id @default(uuid())
  accountId    String   @map("account_id")
  accessToken  String   @map("access_token") @db.Text
  refreshToken String?  @map("refresh_token") @db.Text
  expireAt     DateTime @map("expire_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  account MarketplaceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@map("marketplace_tokens")
}

model MarketplaceProduct {
  id                   String       @id @default(uuid())
  shopId               String       @map("shop_id")
  productId            String       @map("product_id")
  marketplaceProductId String       @map("marketplace_product_id")
  status               RecordStatus @default(ACTIVE)

  shop     MarketplaceShop      @relation(fields: [shopId], references: [id], onDelete: Restrict)
  product  Product              @relation(fields: [productId], references: [id], onDelete: Restrict)
  variants MarketplaceVariant[]

  @@index([shopId])
  @@index([productId])
  @@map("marketplace_products")
}

model MarketplaceVariant {
  id                   String @id @default(uuid())
  marketplaceProductId String @map("marketplace_product_id")
  variantId            String @map("variant_id")
  marketplaceSku       String @map("marketplace_sku")
  marketplaceVariantId String @map("marketplace_variant_id")

  marketplaceProduct MarketplaceProduct @relation(fields: [marketplaceProductId], references: [id], onDelete: Cascade)
  variant            ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([marketplaceProductId])
  @@index([variantId])
  @@map("marketplace_variants")
}

model MarketplaceInventory {
  id          String    @id @default(uuid())
  variantId   String    @map("variant_id")
  shopId      String    @map("shop_id")
  inventoryId String?   @map("inventory_id")
  stock       Int       @default(0)
  reserved    Int       @default(0)
  lastSync    DateTime? @map("last_sync")

  variant   ProductVariant     @relation(fields: [variantId], references: [id], onDelete: Restrict)
  shop      MarketplaceShop    @relation(fields: [shopId], references: [id], onDelete: Restrict)
  inventory InventoryLocation? @relation(fields: [inventoryId], references: [id], onDelete: SetNull)

  @@index([variantId])
  @@index([shopId])
  @@index([inventoryId])
  @@map("marketplace_inventories")
}

model MarketplaceOrder {
  id                 String   @id @default(uuid())
  shopId             String   @map("shop_id")
  salesOrderId       String?  @unique @map("sales_order_id")
  marketplaceOrderId String   @map("marketplace_order_id")
  orderStatus        String   @map("order_status")
  buyerName          String?  @map("buyer_name")
  orderDate          DateTime @map("order_date")
  createdAt          DateTime @default(now()) @map("created_at")

  shop       MarketplaceShop        @relation(fields: [shopId], references: [id], onDelete: Restrict)
  salesOrder SalesOrder?            @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  items      MarketplaceOrderItem[]
  shipments  MarketplaceShipment[]

  @@index([shopId])
  @@map("marketplace_orders")
}

model MarketplaceOrderItem {
  id                 String  @id @default(uuid())
  marketplaceOrderId String  @map("marketplace_order_id")
  variantId          String  @map("variant_id")
  quantity           Int
  price              Decimal @db.Decimal(12, 2)

  order   MarketplaceOrder @relation(fields: [marketplaceOrderId], references: [id], onDelete: Cascade)
  variant ProductVariant   @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([marketplaceOrderId])
  @@index([variantId])
  @@map("marketplace_order_items")
}

model MarketplaceShipment {
  id                 String  @id @default(uuid())
  marketplaceOrderId String  @map("marketplace_order_id")
  shipmentId         String? @unique @map("shipment_id")
  trackingNo         String? @map("tracking_no")
  carrier            String?
  syncStatus         String  @default("PENDING") @map("sync_status")

  order    MarketplaceOrder @relation(fields: [marketplaceOrderId], references: [id], onDelete: Restrict)
  shipment Shipment?        @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([marketplaceOrderId])
  @@map("marketplace_shipments")
}

model MarketplaceWebhook {
  id            String   @id @default(uuid())
  marketplaceId String   @map("marketplace_id")
  event         String
  payload       Json
  processed     Boolean  @default(false)
  retryCount    Int      @default(0) @map("retry_count")
  createdAt     DateTime @default(now()) @map("created_at")

  marketplace Marketplace @relation(fields: [marketplaceId], references: [id], onDelete: Restrict)

  @@index([marketplaceId])
  @@map("marketplace_webhooks")
}

model MarketplaceJob {
  id         String    @id @default(uuid())
  type       String
  payload    Json
  status     String    @default("PENDING")
  retry      Int       @default(0)
  startedAt  DateTime? @map("started_at")
  finishedAt DateTime? @map("finished_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("marketplace_jobs")
}

model MarketplaceSyncLog {
  id         String    @id @default(uuid())
  type       String
  direction  String // INBOUND, OUTBOUND
  status     String
  startedAt  DateTime  @default(now()) @map("started_at")
  finishedAt DateTime? @map("finished_at")
  message    String?   @db.Text

  @@map("marketplace_sync_logs")
}

model MarketplaceErrorLog {
  id        String   @id @default(uuid())
  shopId    String?  @map("shop_id")
  api       String
  request   Json?
  response  Json?
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  shop MarketplaceShop? @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@map("marketplace_error_logs")
}

//////////////////////////////////////////////////////
// SPRINT 8: ORDER MANAGEMENT SYSTEM (OMS)
//////////////////////////////////////////////////////

model OrderSource {
  id   String @id @default(uuid())
  code String @unique
  name String

  orders Order[]

  @@map("order_sources")
}

model Order {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  storeId        String   @map("store_id")
  sourceId       String   @map("source_id")
  customerId     String?  @map("customer_id")
  orderNo        String   @map("order_no")
  orderDate      DateTime @map("order_date")
  status         String
  priority       Int      @default(0)
  currency       String   @default("THB")
  grandTotal     Decimal  @map("grand_total") @db.Decimal(18, 4)

  // Enterprise Features
  slaDueDate DateTime? @map("sla_due_date") // SLA Management
  riskLevel  String?   @map("risk_level") // Fraud & Risk Detection

  organization Organization @relation(fields: [organizationId], references: [id])
  store        Store        @relation(fields: [storeId], references: [id])
  source       OrderSource  @relation(fields: [sourceId], references: [id])
  customer     Customer?    @relation(fields: [customerId], references: [id])

  items           OrderItem[]
  statusHistories OrderStatusHistory[]
  allocations     Allocation[]
  packingBoxes    PackingBox[]
  backOrders      BackOrder[]
  cancelOrders    CancelOrder[]
  holds           OrderHold[]
  notes           OrderNote[]
  tags            OrderTag[]

  salesOrders  SalesOrder[]
  VoucherUsage VoucherUsage[]

  @@unique([organizationId, orderNo])
  @@index([organizationId])
  @@index([storeId])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(uuid())
  orderId      String  @map("order_id")
  variantId    String  @map("variant_id")
  quantity     Int
  allocatedQty Int     @default(0) @map("allocated_qty")
  shippedQty   Int     @default(0) @map("shipped_qty")
  price        Decimal @db.Decimal(18, 4)

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  allocationItems AllocationItem[]
  backOrders      BackOrder[]
  cancelItems     CancelOrderItem[]

  @@index([orderId])
  @@index([variantId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  status    String
  createdAt DateTime @default(now()) @map("created_at")
  createdBy String?  @map("created_by")

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  creator User? @relation(fields: [createdBy], references: [id])

  @@index([orderId])
  @@map("order_status_histories")
}

model Allocation {
  id          String @id @default(uuid())
  orderId     String @map("order_id")
  warehouseId String @map("warehouse_id")
  status      String

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  items        AllocationItem[]
  fulfillments Fulfillment[]

  @@index([orderId])
  @@index([warehouseId])
  @@map("allocations")
}

model AllocationItem {
  id           String @id @default(uuid())
  allocationId String @map("allocation_id")
  orderItemId  String @map("order_item_id")
  variantId    String @map("variant_id")
  quantity     Int

  allocation Allocation     @relation(fields: [allocationId], references: [id], onDelete: Cascade)
  orderItem  OrderItem      @relation(fields: [orderItemId], references: [id])
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  @@index([allocationId])
  @@index([orderItemId])
  @@map("allocation_items")
}

model Fulfillment {
  id            String  @id @default(uuid())
  allocationId  String  @map("allocation_id")
  pickingWaveId String? @map("picking_wave_id")
  status        String
  assignedTo    String? @map("assigned_to")

  allocation  Allocation   @relation(fields: [allocationId], references: [id], onDelete: Restrict)
  pickingWave PickingWave? @relation(fields: [pickingWaveId], references: [id], onDelete: SetNull)
  assignee    User?        @relation(fields: [assignedTo], references: [id])

  items FulfillmentItem[]

  @@index([allocationId])
  @@index([pickingWaveId])
  @@map("fulfillments")
}

model FulfillmentItem {
  id            String @id @default(uuid())
  fulfillmentId String @map("fulfillment_id")
  variantId     String @map("variant_id")
  quantity      Int

  fulfillment Fulfillment    @relation(fields: [fulfillmentId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id])

  @@index([fulfillmentId])
  @@index([variantId])
  @@map("fulfillment_items")
}

model PickingWave {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  warehouseId    String  @map("warehouse_id")
  waveNo         String  @map("wave_no")
  status         String
  zoneId         String? @map("zone_id") // Wave & Batch Picking Optimization

  organization Organization @relation(fields: [organizationId], references: [id])
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])

  fulfillments Fulfillment[]
  PickingTask  PickingTask[]

  @@unique([organizationId, waveNo])
  @@index([organizationId])
  @@index([warehouseId])
  @@map("picking_waves")
}

model PackingBox {
  id      String   @id @default(uuid())
  orderId String   @map("order_id")
  boxNo   String   @map("box_no")
  weight  Decimal? @db.Decimal(10, 4)
  width   Decimal? @db.Decimal(10, 4)
  height  Decimal? @db.Decimal(10, 4)
  length  Decimal? @db.Decimal(10, 4)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  shipmentLabels  ShipmentLabel[]
  PackingTaskItem PackingTaskItem[]

  @@index([orderId])
  @@map("packing_boxes")
}

model ShipmentLabel {
  id           String  @id @default(uuid())
  packingBoxId String  @map("packing_box_id")
  shipmentId   String? @map("shipment_id")
  pdf          String?
  trackingNo   String? @map("tracking_no")

  packingBox PackingBox @relation(fields: [packingBoxId], references: [id], onDelete: Cascade)
  shipment   Shipment?  @relation(fields: [shipmentId], references: [id])

  @@index([packingBoxId])
  @@index([shipmentId])
  @@map("shipment_labels")
}

model BackOrder {
  id          String @id @default(uuid())
  orderId     String @map("order_id")
  orderItemId String @map("order_item_id")
  variantId   String @map("variant_id")
  quantity    Int

  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem      @relation(fields: [orderItemId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
  @@index([variantId])
  @@map("back_orders")
}

model CancelOrder {
  id      String   @id @default(uuid())
  orderId String   @map("order_id")
  reason  String?
  refund  Decimal? @db.Decimal(18, 4)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  items CancelOrderItem[] // Partial Cancellation

  @@index([orderId])
  @@map("cancel_orders")
}

model CancelOrderItem {
  id            String @id @default(uuid())
  cancelOrderId String @map("cancel_order_id")
  orderItemId   String @map("order_item_id")
  quantity      Int

  cancelOrder CancelOrder @relation(fields: [cancelOrderId], references: [id], onDelete: Cascade)
  orderItem   OrderItem   @relation(fields: [orderItemId], references: [id])

  @@index([cancelOrderId])
  @@index([orderItemId])
  @@map("cancel_order_items")
}

model OrderHold {
  id      String @id @default(uuid())
  orderId String @map("order_id")
  reason  String

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_holds")
}

model OrderTag {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  name           String

  organization Organization @relation(fields: [organizationId], references: [id])
  orders       Order[]

  @@index([organizationId])
  @@map("order_tags")
}

model OrderNote {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  message   String
  createdBy String? @map("created_by")

  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  creator User? @relation(fields: [createdBy], references: [id])

  @@index([orderId])
  @@map("order_notes")
}

//////////////////////////////////////////////////////
// ENTERPRISE RULES ENGINE
//////////////////////////////////////////////////////

model AllocationRule {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  name           String
  priority       Int     @default(0)
  condition      Json?
  action         Json?
  isActive       Boolean @default(true) @map("is_active")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("allocation_rules")
}

model ShippingRule {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  name           String
  priority       Int     @default(0)
  condition      Json?
  action         Json?
  isActive       Boolean @default(true) @map("is_active")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("shipping_rules")
}

model AutomationRule {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  trigger        String
  condition      Json?
  action         Json?
  isActive       Boolean @default(true) @map("is_active")

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("automation_rules")
}

//////////////////////////////////////////////////////
// SPRINT 9: WAREHOUSE MANAGEMENT SYSTEM (WMS)
//////////////////////////////////////////////////////

model InventoryPolicy {
  id                 String  @id @default(uuid())
  organizationId     String  @map("organization_id")
  name               String
  pickingStrategy    String  @default("FIFO") // FIFO, FEFO, LIFO
  abcClass           String  @default("C") // A, B, C
  allowNegativeStock Boolean @default(false) @map("allow_negative_stock")
  lotTracking        Boolean @default(false) @map("lot_tracking")
  serialTracking     Boolean @default(false) @map("serial_tracking")
  expiryTracking     Boolean @default(false) @map("expiry_tracking")

  products Product[]

  @@map("wms_inventory_policies")
}

model WarehouseZone {
  id          String @id @default(uuid())
  warehouseId String @map("warehouse_id")
  code        String
  name        String
  type        String // Receiving, Storage, Picking, Packing, Damage, Return, Cold Room

  warehouse Warehouse        @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  aisles    WarehouseAisle[]

  @@map("wms_warehouse_zones")
}

model WarehouseAisle {
  id     String @id @default(uuid())
  zoneId String @map("zone_id")
  code   String // A01

  zone  WarehouseZone   @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  racks WarehouseRack[]

  @@map("wms_warehouse_aisles")
}

model WarehouseRack {
  id      String @id @default(uuid())
  aisleId String @map("aisle_id")
  code    String // Rack A

  aisle   WarehouseAisle   @relation(fields: [aisleId], references: [id], onDelete: Cascade)
  shelves WarehouseShelf[]

  @@map("wms_warehouse_racks")
}

model WarehouseShelf {
  id     String @id @default(uuid())
  rackId String @map("rack_id")
  code   String

  rack WarehouseRack  @relation(fields: [rackId], references: [id], onDelete: Cascade)
  bins WarehouseBin[]

  @@map("wms_warehouse_shelves")
}

model WarehouseBin {
  id      String @id @default(uuid())
  shelfId String @map("shelf_id")
  code    String // 01

  shelf     WarehouseShelf      @relation(fields: [shelfId], references: [id], onDelete: Cascade)
  locations WarehouseLocation[]

  @@map("wms_warehouse_bins")
}

model WarehouseLocation {
  id          String  @id @default(uuid())
  warehouseId String  @map("warehouse_id")
  binId       String? @map("bin_id")

  code    String       @unique
  barcode String       @unique
  status  RecordStatus @default(ACTIVE)

  warehouse Warehouse     @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  bin       WarehouseBin? @relation(fields: [binId], references: [id], onDelete: SetNull)

  inventoryLocs     InventoryLocation[]
  movementsFrom     InventoryMovement[]   @relation("MovementFromLoc")
  movementsTo       InventoryMovement[]   @relation("MovementToLoc")
  transferFroms     StockTransferItem[]   @relation("TransferFromLocation")
  transferTos       StockTransferItem[]   @relation("TransferToLocation")
  goodsReceiveItems GoodsReceiveItem[]
  adjustmentItems   StockAdjustmentItem[]

  pickingTaskItems PickingTaskItem[]
  cycleCountItems  CycleCountItem[]
  putAwayFroms     PutAwayItem[]     @relation("PutAwayFromLoc")
  putAwayTos       PutAwayItem[]     @relation("PutAwayToLoc")

  @@map("wms_warehouse_locations")
}

model InventoryLot {
  id              String    @id @default(uuid())
  variantId       String    @map("variant_id")
  lotNumber       String    @map("lot_number")
  manufactureDate DateTime? @map("manufacture_date")
  expireDate      DateTime? @map("expire_date")
  createdAt       DateTime  @default(now()) @map("created_at")

  variant            ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  inventoryLocations InventoryLocation[]
  movements          InventoryMovement[]
  adjustmentItems    StockAdjustmentItem[]

  @@index([variantId])
  @@map("wms_inventory_lots")
}

model InventorySerial {
  id           String   @id @default(uuid())
  variantId    String   @map("variant_id")
  serialNumber String   @map("serial_number")
  status       String   @default("AVAILABLE")
  createdAt    DateTime @default(now()) @map("created_at")

  variant            ProductVariant        @relation(fields: [variantId], references: [id], onDelete: Cascade)
  inventoryLocations InventoryLocation[]
  movements          InventoryMovement[]
  adjustmentItems    StockAdjustmentItem[]

  @@unique([variantId, serialNumber], map: "uk_wms_inventory_serial")
  @@index([variantId])
  @@map("wms_inventory_serials")
}

model InventoryLocation {
  id                  String  @id @default(uuid())
  warehouseLocationId String  @map("warehouse_location_id")
  productVariantId    String  @map("product_variant_id")
  lotId               String? @map("lot_id")
  serialId            String? @map("serial_id")

  quantity     Int @default(0)
  reservedQty  Int @default(0) @map("reserved_qty")
  availableQty Int @default(0) @map("available_qty")
  damagedQty   Int @default(0) @map("damaged_qty")
  allocatedQty Int @default(0) @map("allocated_qty")

  lastMovementAt DateTime @default(now()) @map("last_movement_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  location             WarehouseLocation      @relation(fields: [warehouseLocationId], references: [id], onDelete: Cascade)
  variant              ProductVariant         @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  lot                  InventoryLot?          @relation(fields: [lotId], references: [id])
  serial               InventorySerial?       @relation(fields: [serialId], references: [id])
  MarketplaceInventory MarketplaceInventory[]

  @@unique([warehouseLocationId, productVariantId, lotId, serialId], map: "uk_wms_inv_loc")
  @@map("wms_inventory_locations")
}

model InventoryMovement {
  id             String   @id @default(uuid())
  type           String // RECEIVING, PUTAWAY, PICKING, PACKING, TRANSFER_IN, TRANSFER_OUT, ADJUSTMENT, RETURN, SALE, PURCHASE
  variantId      String   @map("variant_id")
  fromLocationId String?  @map("from_location_id")
  toLocationId   String?  @map("to_location_id")
  lotId          String?  @map("lot_id")
  serialId       String?  @map("serial_id")
  quantity       Int
  referenceType  String?  @map("reference_type")
  referenceId    String?  @map("reference_id")
  movedBy        String?  @map("moved_by")
  createdAt      DateTime @default(now()) @map("created_at")

  variant ProductVariant     @relation(fields: [variantId], references: [id])
  fromLoc WarehouseLocation? @relation("MovementFromLoc", fields: [fromLocationId], references: [id])
  toLoc   WarehouseLocation? @relation("MovementToLoc", fields: [toLocationId], references: [id])
  lot     InventoryLot?      @relation(fields: [lotId], references: [id])
  serial  InventorySerial?   @relation(fields: [serialId], references: [id])
  mover   User?              @relation(fields: [movedBy], references: [id])

  @@map("wms_inventory_movements")
}

model Receiving {
  id              String  @id @default(uuid())
  warehouseId     String  @map("warehouse_id")
  purchaseOrderId String? @map("purchase_order_id")
  goodsReceiveId  String? @map("goods_receive_id")
  status          String // PENDING, IN_PROGRESS, COMPLETED

  warehouse    Warehouse     @relation(fields: [warehouseId], references: [id])
  goodsReceive GoodsReceive? @relation(fields: [goodsReceiveId], references: [id])

  items    ReceivingItem[]
  putAways PutAway[]

  @@map("wms_receivings")
}

model ReceivingItem {
  id          String @id @default(uuid())
  receivingId String @map("receiving_id")
  variantId   String @map("variant_id")
  expectedQty Int    @map("expected_qty")
  receivedQty Int    @default(0) @map("received_qty")

  receiving Receiving      @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])

  @@map("wms_receiving_items")
}

model PutAway {
  id          String  @id @default(uuid())
  receivingId String  @map("receiving_id")
  status      String // PENDING, IN_PROGRESS, COMPLETED
  assignedTo  String? @map("assigned_to")

  receiving Receiving @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  assignee  User?     @relation(fields: [assignedTo], references: [id])

  items PutAwayItem[]

  @@map("wms_put_aways")
}

model PutAwayItem {
  id             String  @id @default(uuid())
  putAwayId      String  @map("put_away_id")
  variantId      String  @map("variant_id")
  fromLocationId String? @map("from_location_id")
  toLocationId   String  @map("to_location_id")
  quantity       Int
  status         String  @default("PENDING")

  putAway      PutAway            @relation(fields: [putAwayId], references: [id], onDelete: Cascade)
  variant      ProductVariant     @relation(fields: [variantId], references: [id])
  fromLocation WarehouseLocation? @relation("PutAwayFromLoc", fields: [fromLocationId], references: [id])
  toLocation   WarehouseLocation  @relation("PutAwayToLoc", fields: [toLocationId], references: [id])

  @@map("wms_put_away_items")
}

model PickingTask {
  id          String  @id @default(uuid())
  warehouseId String  @map("warehouse_id")
  waveId      String? @map("wave_id")
  assignedTo  String? @map("assigned_to")
  status      String

  warehouse Warehouse    @relation(fields: [warehouseId], references: [id])
  wave      PickingWave? @relation(fields: [waveId], references: [id])
  assignee  User?        @relation(fields: [assignedTo], references: [id])

  items        PickingTaskItem[]
  packingTasks PackingTask[]

  @@map("wms_picking_tasks")
}

model PickingTaskItem {
  id            String @id @default(uuid())
  pickingTaskId String @map("picking_task_id")
  locationId    String @map("location_id")
  variantId     String @map("variant_id")
  expectedQty   Int    @map("expected_qty")
  pickedQty     Int    @default(0) @map("picked_qty")

  pickingTask PickingTask       @relation(fields: [pickingTaskId], references: [id], onDelete: Cascade)
  location    WarehouseLocation @relation(fields: [locationId], references: [id])
  variant     ProductVariant    @relation(fields: [variantId], references: [id])

  @@map("wms_picking_task_items")
}

model PackingTask {
  id            String  @id @default(uuid())
  pickingTaskId String  @map("picking_task_id")
  status        String
  assignedTo    String? @map("assigned_to")

  pickingTask PickingTask @relation(fields: [pickingTaskId], references: [id], onDelete: Cascade)
  assignee    User?       @relation(fields: [assignedTo], references: [id])

  items PackingTaskItem[]

  @@map("wms_packing_tasks")
}

model PackingTaskItem {
  id            String  @id @default(uuid())
  packingTaskId String  @map("packing_task_id")
  variantId     String  @map("variant_id")
  quantity      Int
  boxId         String? @map("box_id")

  packingTask PackingTask    @relation(fields: [packingTaskId], references: [id], onDelete: Cascade)
  variant     ProductVariant @relation(fields: [variantId], references: [id])
  box         PackingBox?    @relation(fields: [boxId], references: [id])

  @@map("wms_packing_task_items")
}

model CycleCount {
  id          String   @id @default(uuid())
  warehouseId String   @map("warehouse_id")
  countDate   DateTime @map("count_date")
  status      String
  assignedTo  String?  @map("assigned_to")

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  assignee  User?     @relation(fields: [assignedTo], references: [id])

  items CycleCountItem[]

  @@map("wms_cycle_counts")
}

model CycleCountItem {
  id           String @id @default(uuid())
  cycleCountId String @map("cycle_count_id")
  locationId   String @map("location_id")
  variantId    String @map("variant_id")
  systemQty    Int    @map("system_qty")
  countQty     Int?   @map("count_qty")
  difference   Int?

  cycleCount CycleCount        @relation(fields: [cycleCountId], references: [id], onDelete: Cascade)
  location   WarehouseLocation @relation(fields: [locationId], references: [id])
  variant    ProductVariant    @relation(fields: [variantId], references: [id])

  @@map("wms_cycle_count_items")
}

//////////////////////////////////////////////////////
// ENUMS (FINANCIAL)
//////////////////////////////////////////////////////

enum LedgerBookType {
  FINANCIAL
  TAX
  MANAGEMENT
  IFRS
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

//////////////////////////////////////////////////////
// MASTER DATA & STRUCTURE
//////////////////////////////////////////////////////

model AccountGroup {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  code           String
  name           String

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  accounts     Account[]

  @@unique([organizationId, code])
  @@map("fin_account_groups")
}

model Account {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  groupId        String? @map("group_id")
  parentId       String? @map("parent_id")

  code      String
  name      String
  type      AccountType
  isPosting Boolean     @default(true) @map("is_posting")

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  group        AccountGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children     Account[]     @relation("AccountHierarchy")

  journalLines    JournalEntryLine[]
  accountMappings AccountMapping[]

  @@unique([organizationId, code])
  @@map("fin_accounts")
}

model FiscalYear {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  year           Int
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")

  status String @default("OPEN") // OPEN, CLOSED

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  periods      AccountingPeriod[]

  @@unique([organizationId, year])
  @@map("fin_fiscal_years")
}

model AccountingPeriod {
  id           String   @id @default(uuid())
  fiscalYearId String   @map("fiscal_year_id")
  period       Int
  startDate    DateTime @map("start_date")
  endDate      DateTime @map("end_date")

  status String @default("OPEN") // OPEN, CLOSED, LOCKED

  fiscalYear FiscalYear @relation(fields: [fiscalYearId], references: [id], onDelete: Cascade)

  @@unique([fiscalYearId, period])
  @@map("fin_accounting_periods")
}

model LedgerBook {
  id             String         @id @default(uuid())
  organizationId String         @map("organization_id")
  code           String
  name           String
  type           LedgerBookType
  baseCurrency   String         @default("THB") @map("base_currency")
  isDefault      Boolean        @default(false) @map("is_default")

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  journalEntries JournalEntry[]

  @@unique([organizationId, code])
  @@map("fin_ledger_books")
}

model ExchangeRate {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  fromCurrency   String   @map("from_currency")
  toCurrency     String   @map("to_currency")
  rate           Decimal  @db.Decimal(18, 6)
  effectiveDate  DateTime @map("effective_date")
  source         String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@index([organizationId, fromCurrency, toCurrency, effectiveDate])
  @@map("fin_exchange_rates")
}

//////////////////////////////////////////////////////
// ACCOUNTING RULE ENGINE
//////////////////////////////////////////////////////

model AccountingEvent {
  id          String  @id @default(uuid())
  code        String  @unique // GOODS_RECEIVE, SALES_INVOICE, PAYMENT
  name        String
  description String?

  rules AccountingRule[]

  @@map("fin_accounting_events")
}

model AccountingRule {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  eventId        String @map("event_id")
  templateId     String @map("template_id")

  name          String
  priority      Int       @default(0)
  enabled       Boolean   @default(true)
  status        String    @default("DRAFT") // DRAFT, REVIEW, APPROVED, PUBLISHED
  effectiveFrom DateTime? @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  event        AccountingEvent @relation(fields: [eventId], references: [id], onDelete: Restrict)
  template     JournalTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  conditions   RuleCondition[]

  @@map("fin_accounting_rules")
}

model RuleCondition {
  id       String @id @default(uuid())
  ruleId   String @map("rule_id")
  field    String // e.g., "SupplierType", "CustomerGroup", "Currency"
  operator String // e.g., "EQUALS", "IN", "NOT_EQUALS"
  value    String

  rule AccountingRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@map("fin_rule_conditions")
}

model JournalTemplate {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  name           String
  journalId      String  @map("journal_id") // Default Journal to post to
  description    String?

  organization  Organization          @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  journal       Journal               @relation(fields: [journalId], references: [id], onDelete: Restrict)
  rules         AccountingRule[]
  lineTemplates JournalLineTemplate[]

  @@map("fin_journal_templates")
}

model JournalLineTemplate {
  id            String  @id @default(uuid())
  templateId    String  @map("template_id")
  mappingCode   String  @map("mapping_code") // e.g., "INVENTORY_ACCOUNT", "GRNI_ACCOUNT"
  isDebit       Boolean @map("is_debit")
  amountFormula String  @map("amount_formula") // e.g., "100%", "VAT_AMOUNT"

  template JournalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("fin_journal_line_templates")
}

model AccountMapping {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  mappingCode    String  @map("mapping_code") // e.g., "INVENTORY_ACCOUNT"
  referenceType  String? @map("reference_type") // e.g., "ProductCategory", "CustomerGroup"
  referenceId    String? @map("reference_id")
  accountId      String  @map("account_id") // Actual COA Account

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  account      Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)

  @@index([organizationId, mappingCode, referenceType, referenceId])
  @@map("fin_account_mappings")
}

//////////////////////////////////////////////////////
// JOURNALS & LEDGERS
//////////////////////////////////////////////////////

model Journal {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  code           String
  name           String

  status RecordStatus @default(ACTIVE)

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  entries      JournalEntry[]
  templates    JournalTemplate[]

  @@unique([organizationId, code])
  @@map("fin_journals")
}

model JournalEntry {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  journalId      String @map("journal_id")
  ledgerBookId   String @map("ledger_book_id")

  entryNo       String   @map("entry_no")
  date          DateTime
  referenceType String?  @map("reference_type") // e.g., "SalesInvoice"
  referenceId   String?  @map("reference_id")
  description   String?
  status        String   @default("DRAFT") // DRAFT, POSTED, REVERSED
  reversedById  String?  @map("reversed_by_id") // Links to reversing JV

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  journal         Journal        @relation(fields: [journalId], references: [id], onDelete: Restrict)
  ledgerBook      LedgerBook     @relation(fields: [ledgerBookId], references: [id], onDelete: Restrict)
  reversal        JournalEntry?  @relation("ReversedBy", fields: [reversedById], references: [id], onDelete: Restrict)
  reversedEntries JournalEntry[] @relation("ReversedBy")

  lines JournalEntryLine[]

  @@unique([organizationId, entryNo])
  @@map("fin_journal_entries")
}

model JournalEntryLine {
  id             String @id @default(uuid())
  journalEntryId String @map("journal_entry_id")
  accountId      String @map("account_id")

  // Foreign Currency
  currencyCode String  @default("THB") @map("currency_code")
  exchangeRate Decimal @default(1.0) @map("exchange_rate") @db.Decimal(18, 6)
  debitAmount  Decimal @default(0) @map("debit_amount") @db.Decimal(18, 4)
  creditAmount Decimal @default(0) @map("credit_amount") @db.Decimal(18, 4)

  // Base Currency
  baseDebit  Decimal @default(0) @map("base_debit") @db.Decimal(18, 4)
  baseCredit Decimal @default(0) @map("base_credit") @db.Decimal(18, 4)

  description    String?
  costCenterId   String? @map("cost_center_id")
  profitCenterId String? @map("profit_center_id")

  entry        JournalEntry  @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  account      Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  costCenter   CostCenter?   @relation(fields: [costCenterId], references: [id], onDelete: SetNull)
  profitCenter ProfitCenter? @relation(fields: [profitCenterId], references: [id], onDelete: SetNull)

  @@index([journalEntryId])
  @@index([accountId])
  @@map("fin_journal_entry_lines")
}

//////////////////////////////////////////////////////
// AR / AP SUB-LEDGERS
//////////////////////////////////////////////////////

model AccountsReceivable {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  customerId     String @map("customer_id")
  invoiceId      String @map("invoice_id")

  currency       String   @default("THB")
  originalAmount Decimal  @map("original_amount") @db.Decimal(18, 4)
  balance        Decimal  @default(0) @db.Decimal(18, 4)
  dueDate        DateTime @map("due_date")
  status         String   @default("OPEN") // OPEN, PARTIAL, PAID

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  customer     Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  invoice      SalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  payments ARPayment[]

  @@index([customerId])
  @@index([invoiceId])
  @@map("fin_accounts_receivable")
}

model ARPayment {
  id          String   @id @default(uuid())
  arId        String   @map("ar_id")
  paymentDate DateTime @map("payment_date")
  amount      Decimal  @db.Decimal(18, 4)
  bankTransId String?  @map("bank_transaction_id")

  ar              AccountsReceivable @relation(fields: [arId], references: [id], onDelete: Cascade)
  bankTransaction BankTransaction?   @relation(fields: [bankTransId], references: [id], onDelete: SetNull)

  @@index([arId])
  @@map("fin_ar_payments")
}

model AccountsPayable {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  vendorId       String @map("vendor_id")
  invoiceId      String @map("invoice_id") // Links to PurchaseInvoice

  currency       String   @default("THB")
  originalAmount Decimal  @map("original_amount") @db.Decimal(18, 4)
  balance        Decimal  @default(0) @db.Decimal(18, 4)
  dueDate        DateTime @map("due_date")
  status         String   @default("OPEN") // OPEN, PARTIAL, PAID

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  vendor       Vendor          @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  invoice      PurchaseInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)

  payments APPayment[]

  @@index([vendorId])
  @@index([invoiceId])
  @@map("fin_accounts_payable")
}

model APPayment {
  id          String   @id @default(uuid())
  apId        String   @map("ap_id")
  paymentDate DateTime @map("payment_date")
  amount      Decimal  @db.Decimal(18, 4)
  bankTransId String?  @map("bank_transaction_id")

  ap              AccountsPayable  @relation(fields: [apId], references: [id], onDelete: Cascade)
  bankTransaction BankTransaction? @relation(fields: [bankTransId], references: [id], onDelete: SetNull)

  @@index([apId])
  @@map("fin_ap_payments")
}

//////////////////////////////////////////////////////
// CASH & BANK
//////////////////////////////////////////////////////

model CashAccount {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  code           String
  name           String
  balance        Decimal @default(0) @db.Decimal(18, 4)
  currency       String  @default("THB")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  @@unique([organizationId, code])
  @@map("fin_cash_accounts")
}

model BankAccount {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  bankName       String  @map("bank_name")
  accountNo      String  @map("account_no")
  accountName    String  @map("account_name")
  branch         String?
  currency       String  @default("THB")
  balance        Decimal @default(0) @db.Decimal(18, 4)

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  transactions BankTransaction[]

  @@unique([organizationId, accountNo])
  @@map("fin_bank_accounts")
}

model BankTransaction {
  id            String   @id @default(uuid())
  bankAccountId String   @map("bank_account_id")
  date          DateTime
  type          String // DEPOSIT, WITHDRAWAL, TRANSFER, FEE, INTEREST
  reference     String?
  amount        Decimal  @db.Decimal(18, 4)
  description   String?

  bankAccount BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  arPayments  ARPayment[]
  apPayments  APPayment[]

  @@index([bankAccountId])
  @@map("fin_bank_transactions")
}

//////////////////////////////////////////////////////
// TAX, COSTING, & BUDGET
//////////////////////////////////////////////////////

model TaxCode {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  code           String
  name           String
  description    String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  rates        TaxRate[]

  @@unique([organizationId, code])
  @@map("fin_tax_codes")
}

model TaxRate {
  id            String    @id @default(uuid())
  taxCodeId     String    @map("tax_code_id")
  rate          Decimal   @db.Decimal(5, 2)
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")

  taxCode TaxCode @relation(fields: [taxCodeId], references: [id], onDelete: Cascade)

  @@index([taxCodeId])
  @@map("fin_tax_rates")
}

model CostCenter {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  code           String
  name           String

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  journalLines JournalEntryLine[]

  @@unique([organizationId, code])
  @@map("fin_cost_centers")
}

model ProfitCenter {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  code           String
  name           String

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  journalLines JournalEntryLine[]

  @@unique([organizationId, code])
  @@map("fin_profit_centers")
}

model Budget {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  name           String
  year           Int

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  lines        BudgetLine[]

  @@unique([organizationId, name, year])
  @@map("fin_budgets")
}

model BudgetLine {
  id           String  @id @default(uuid())
  budgetId     String  @map("budget_id")
  costCenterId String? @map("cost_center_id")
  amount       Decimal @db.Decimal(18, 4)
  period       Int // 1 to 12

  budget Budget @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
  @@map("fin_budget_lines")
}

//////////////////////////////////////////////////////
// BUSINESS INTELLIGENCE & ANALYTICS (SPRINT 11)
//////////////////////////////////////////////////////

// ==========================================
// 1. DASHBOARD & METRICS
// ==========================================

model Dashboard {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  name           String
  description    String?
  roleAccess     String? @map("role_access") // JSON array of roles or permissions
  isDefault      Boolean @default(false) @map("is_default")

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  widgets      DashboardWidget[]

  @@index([organizationId])
  @@map("bi_dashboards")
}

model DashboardWidget {
  id          String @id @default(uuid())
  dashboardId String @map("dashboard_id")
  title       String
  type        String // CHART_LINE, CHART_BAR, SCORECARD, TABLE
  config      String // JSON configuration for the widget (metrics, dimensions, filters)
  positionX   Int    @map("position_x")
  positionY   Int    @map("position_y")
  width       Int
  height      Int

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
  @@map("bi_dashboard_widgets")
}

model MetricDefinition {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  code           String // e.g., GROSS_PROFIT, INVENTORY_TURNOVER
  name           String
  description    String?
  formula        String // JSON or Expression defining how to calculate it
  unit           String? // e.g., Currency, Percentage, Count

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  kpis         KPI[]
  histories    KPIHistory[]

  @@unique([organizationId, code])
  @@map("bi_metric_definitions")
}

model KPI {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  metricId       String   @map("metric_id")
  name           String
  targetValue    Decimal  @map("target_value") @db.Decimal(18, 4)
  warningValue   Decimal? @map("warning_value") @db.Decimal(18, 4)
  period         String // DAILY, WEEKLY, MONTHLY, YEARLY

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  metric       MetricDefinition @relation(fields: [metricId], references: [id], onDelete: Restrict)

  @@index([organizationId])
  @@map("bi_kpis")
}

model KPIHistory {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  metricId       String   @map("metric_id")
  metricDate     DateTime @map("metric_date") @db.Date

  // Dimensions for Data Scope Resolution
  storeId       String? @map("store_id")
  warehouseId   String? @map("warehouse_id")
  marketplaceId String? @map("marketplace_id")

  actualValue Decimal @map("actual_value") @db.Decimal(18, 4)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  metric       MetricDefinition @relation(fields: [metricId], references: [id], onDelete: Restrict)

  @@index([organizationId, metricId, metricDate])
  @@map("bi_kpi_history")
}

// ==========================================
// 2. REPORTING ENGINE
// ==========================================

model ReportTemplate {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  code           String
  name           String
  description    String?
  baseQuery      String  @map("base_query") // JSON defining the semantic model / base facts
  columns        String // JSON definition of available columns
  roleAccess     String? @map("role_access")

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  savedReports SavedReport[]
  caches       ReportCache[]

  @@unique([organizationId, code])
  @@map("bi_report_templates")
}

model SavedReport {
  id         String  @id @default(uuid())
  templateId String  @map("template_id")
  name       String
  config     String // JSON definition of selected columns, filters, grouping, sorting
  isPublic   Boolean @default(false) @map("is_public")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  template   ReportTemplate    @relation(fields: [templateId], references: [id], onDelete: Cascade)
  schedules  ScheduledReport[]
  executions ReportExecution[]

  @@index([templateId])
  @@map("bi_saved_reports")
}

model ScheduledReport {
  id             String @id @default(uuid())
  savedReportId  String @map("saved_report_id")
  cronExpression String @map("cron_expression")
  recipients     String // JSON array of emails or user IDs
  format         String @default("PDF") // PDF, EXCEL, CSV

  status RecordStatus @default(ACTIVE)

  savedReport SavedReport @relation(fields: [savedReportId], references: [id], onDelete: Cascade)

  @@index([savedReportId])
  @@map("bi_scheduled_reports")
}

model ReportExecution {
  id            String   @id @default(uuid())
  savedReportId String   @map("saved_report_id")
  executedAt    DateTime @default(now()) @map("executed_at")
  executedBy    String?  @map("executed_by") // User ID
  durationMs    Int      @map("duration_ms")
  status        String // SUCCESS, FAILED
  errorMessage  String?  @map("error_message")
  fileUrl       String?  @map("file_url")

  savedReport SavedReport @relation(fields: [savedReportId], references: [id], onDelete: Cascade)

  @@index([savedReportId])
  @@map("bi_report_executions")
}

model ReportCache {
  id         String   @id @default(uuid())
  templateId String   @map("template_id")
  cacheKey   String   @map("cache_key") // Hash of parameters
  resultData String // JSON payload or URL to payload
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  template ReportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, cacheKey])
  @@map("bi_report_caches")
}

// ==========================================
// 3. DATA WAREHOUSE (FACT TABLES)
// ==========================================

model FactSales {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  dateId         DateTime @map("date_id") @db.Date // DimDate essentially

  // Dimensions
  storeId       String? @map("store_id")
  marketplaceId String? @map("marketplace_id")
  customerId    String? @map("customer_id")
  productId     String? @map("product_id")
  salesOrderId  String? @map("sales_order_id")
  invoiceId     String? @map("invoice_id")
  invoiceItemId String? @map("invoice_item_id")

  // Measures (Line-level Granularity)
  quantity       Decimal @db.Decimal(18, 4)
  unitPrice      Decimal @map("unit_price") @db.Decimal(18, 4)
  discount       Decimal @db.Decimal(18, 4)
  netSalesAmount Decimal @map("net_sales_amount") @db.Decimal(18, 4)
  cogs           Decimal @default(0) @db.Decimal(18, 4)
  grossProfit    Decimal @default(0) @map("gross_profit") @db.Decimal(18, 4)
  taxAmount      Decimal @default(0) @map("tax_amount") @db.Decimal(18, 4)

  @@index([organizationId, dateId])
  @@index([productId])
  @@index([customerId])
  @@index([storeId])
  @@map("dw_fact_sales")
}

model FactPurchase {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  dateId         DateTime @map("date_id") @db.Date

  // Dimensions
  storeId         String? @map("store_id")
  warehouseId     String? @map("warehouse_id")
  vendorId        String? @map("vendor_id")
  productId       String? @map("product_id")
  purchaseOrderId String? @map("purchase_order_id")
  invoiceId       String? @map("invoice_id")
  invoiceItemId   String? @map("invoice_item_id")

  // Measures (Line-level Granularity)
  quantity          Decimal @db.Decimal(18, 4)
  unitPrice         Decimal @map("unit_price") @db.Decimal(18, 4)
  discount          Decimal @db.Decimal(18, 4)
  netPurchaseAmount Decimal @map("net_purchase_amount") @db.Decimal(18, 4)
  taxAmount         Decimal @default(0) @map("tax_amount") @db.Decimal(18, 4)

  @@index([organizationId, dateId])
  @@index([productId])
  @@index([vendorId])
  @@map("dw_fact_purchases")
}

model FactInventoryMovement {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  dateId         DateTime @map("date_id") @db.Date

  // Dimensions
  warehouseId  String? @map("warehouse_id")
  productId    String? @map("product_id")
  movementType String  @map("movement_type") // RECEIVE, SALE, TRANSFER, ADJUSTMENT
  referenceDoc String? @map("reference_doc")

  // Measures (Deltas)
  quantityChange  Decimal @map("quantity_change") @db.Decimal(18, 4)
  costValueChange Decimal @map("cost_value_change") @db.Decimal(18, 4)

  @@index([organizationId, dateId])
  @@index([warehouseId])
  @@index([productId])
  @@map("dw_fact_inventory_movements")
}

model FactInventorySnapshot {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  dateId         DateTime @map("date_id") @db.Date

  // Dimensions
  warehouseId String? @map("warehouse_id")
  productId   String? @map("product_id")

  // Measures (End of Day Balances)
  closingQuantity  Decimal @map("closing_quantity") @db.Decimal(18, 4)
  closingCostValue Decimal @map("closing_cost_value") @db.Decimal(18, 4)

  @@unique([organizationId, dateId, warehouseId, productId], map: "uk_dw_inventory_snapshot")
  @@index([organizationId, dateId])
  @@map("dw_fact_inventory_snapshots")
}

model FactFinance {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  dateId         DateTime @map("date_id") @db.Date

  // Dimensions
  ledgerBookId   String  @map("ledger_book_id")
  accountId      String  @map("account_id")
  costCenterId   String? @map("cost_center_id")
  profitCenterId String? @map("profit_center_id")

  // Measures (Aggregated Daily Balances in Base Currency)
  dailyDebit     Decimal @map("daily_debit") @db.Decimal(18, 4)
  dailyCredit    Decimal @map("daily_credit") @db.Decimal(18, 4)
  netMovement    Decimal @map("net_movement") @db.Decimal(18, 4)
  closingBalance Decimal @map("closing_balance") @db.Decimal(18, 4)

  @@unique([organizationId, ledgerBookId, accountId, dateId], map: "uk_finance_fact")
  @@index([organizationId, dateId])
  @@map("dw_fact_finance")
}

// ==========================================
// 4. ALERTS & FORECASTING
// ==========================================

model AlertRule {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  name           String
  description    String?
  metricId       String? @map("metric_id") // Optional link to semantic layer
  condition      String // JSON definition of the rule trigger (e.g., Value < 100)
  actionConfig   String // JSON (Email, In-App Notification)

  status RecordStatus @default(ACTIVE)

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  histories    AlertHistory[]

  @@index([organizationId])
  @@map("bi_alert_rules")
}

model AlertHistory {
  id           String    @id @default(uuid())
  ruleId       String    @map("rule_id")
  triggeredAt  DateTime  @default(now()) @map("triggered_at")
  triggerValue String    @map("trigger_value") // JSON of the state that triggered it
  status       String    @default("NEW") // NEW, ACKNOWLEDGED, RESOLVED
  resolvedAt   DateTime? @map("resolved_at")

  rule AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@map("bi_alert_histories")
}

model ForecastModel {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  name           String
  targetMetric   String @map("target_metric") // e.g., SALES, DEMAND, INVENTORY
  algorithm      String // MOVING_AVERAGE, EXPONENTIAL_SMOOTHING, AI_MODEL
  config         String // JSON (e.g., lookback_periods: 3)

  status RecordStatus @default(ACTIVE)

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  results      ForecastResult[]

  @@index([organizationId])
  @@map("bi_forecast_models")
}

model ForecastResult {
  id         String   @id @default(uuid())
  modelId    String   @map("model_id")
  targetDate DateTime @map("target_date") @db.Date

  // Dimensions
  productId   String? @map("product_id")
  warehouseId String? @map("warehouse_id")

  forecastValue  Decimal  @map("forecast_value") @db.Decimal(18, 4)
  confidenceLow  Decimal? @map("confidence_low") @db.Decimal(18, 4)
  confidenceHigh Decimal? @map("confidence_high") @db.Decimal(18, 4)

  createdAt DateTime @default(now()) @map("created_at")

  model ForecastModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId, targetDate])
  @@map("bi_forecast_results")
}

//////////////////////////////////////////////////////
// PROMOTION & PRICING ENGINE (SPRINT 12)
//////////////////////////////////////////////////////

// ==========================================
// 1. CAMPAIGN & PROMOTIONS
// ==========================================

model Campaign {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  code           String
  name           String
  description    String?
  startDate      DateTime @map("start_date")
  endDate        DateTime @map("end_date")
  budgetAmount   Decimal? @map("budget_amount") @db.Decimal(18, 4)
  usedAmount     Decimal  @default(0) @map("used_amount") @db.Decimal(18, 4)

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  promotions     Promotion[]
  voucherBatches VoucherBatch[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@map("promo_campaigns")
}

model Promotion {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  campaignId     String? @map("campaign_id")
  code           String
  name           String
  description    String?

  // Stacking & Priority
  priority     Int     @default(0)
  isCombinable Boolean @default(false) @map("is_combinable")
  autoApply    Boolean @default(false) @map("auto_apply") // Apply without code

  // Limits
  usageLimit Int? @map("usage_limit") // Max times this promotion can be used globally
  usageCount Int  @default(0) @map("usage_count")
  userLimit  Int? @map("user_limit") // Max times per user

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  tiers      PromotionTier[]
  conditions PromotionCondition[]
  actions    PromotionAction[]
  vouchers   Voucher[]

  @@unique([organizationId, code])
  @@index([organizationId, status])
  @@map("promo_promotions")
}

model PromotionTier {
  id          String @id @default(uuid())
  promotionId String @map("promotion_id")
  name        String
  tierLevel   Int    @map("tier_level") // 1, 2, 3 (for multi-tier promos like Buy 1 Get 10%, Buy 2 Get 20%)

  promotion  Promotion            @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  conditions PromotionCondition[]
  actions    PromotionAction[]

  @@index([promotionId])
  @@map("promo_tiers")
}

// ==========================================
// 2. RULE ENGINE (CONDITIONS & ACTIONS)
// ==========================================

model PromotionCondition {
  id          String  @id @default(uuid())
  promotionId String? @map("promotion_id")
  tierId      String? @map("tier_id")

  type     String // e.g., MIN_SPEND, MIN_QUANTITY, HAS_CATEGORY, HAS_BRAND, CUSTOMER_SEGMENT
  operator String // e.g., GREATER_THAN, EQUALS, IN, CONTAINS
  value    String // JSON string of the target value(s)

  promotion Promotion?     @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  tier      PromotionTier? @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@index([promotionId])
  @@index([tierId])
  @@map("promo_conditions")
}

model PromotionAction {
  id          String  @id @default(uuid())
  promotionId String? @map("promotion_id")
  tierId      String? @map("tier_id")

  type         String // e.g., DISCOUNT_PERCENT, DISCOUNT_FIXED, FREE_SHIPPING, FREE_GIFT
  value        Decimal  @db.Decimal(18, 4) // e.g., 10 for 10%, or 500 for 500 THB
  maxDiscount  Decimal? @map("max_discount") @db.Decimal(18, 4)
  targetConfig String? // JSON config for what the action applies to (e.g., Specific Product IDs)

  promotion Promotion?     @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  tier      PromotionTier? @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@index([promotionId])
  @@index([tierId])
  @@map("promo_actions")
}

// ==========================================
// 3. VOUCHER & COUPON
// ==========================================

model VoucherBatch {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  campaignId     String? @map("campaign_id")
  codePrefix     String? @map("code_prefix")
  quantity       Int

  createdAt DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  campaign     Campaign?    @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  vouchers     Voucher[]

  @@index([organizationId])
  @@map("promo_voucher_batches")
}

model Voucher {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  batchId        String? @map("batch_id")
  promotionId    String  @map("promotion_id")
  customerId     String? @map("customer_id") // If assigned to a specific customer

  code       String
  isClaimed  Boolean @default(false) @map("is_claimed")
  usageCount Int     @default(0) @map("usage_count")

  status    RecordStatus @default(ACTIVE) // ACTIVE, INACTIVE, REDEEMED
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  batch        VoucherBatch?  @relation(fields: [batchId], references: [id], onDelete: SetNull)
  promotion    Promotion      @relation(fields: [promotionId], references: [id], onDelete: Restrict)
  customer     Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  usages       VoucherUsage[]

  @@unique([organizationId, code])
  @@index([promotionId])
  @@index([customerId])
  @@map("promo_vouchers")
}

model VoucherUsage {
  id             String  @id @default(uuid())
  voucherId      String  @map("voucher_id")
  customerId     String  @map("customer_id")
  orderId        String  @map("order_id")
  discountAmount Decimal @map("discount_amount") @db.Decimal(18, 4)

  usedAt DateTime @default(now()) @map("used_at")

  voucher  Voucher  @relation(fields: [voucherId], references: [id], onDelete: Restrict)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)
  order    Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([voucherId])
  @@index([customerId])
  @@index([orderId])
  @@map("promo_voucher_usages")
}

// ==========================================
// 4. BUNDLE (Virtual Sets)
// ==========================================

model ProductBundle {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  code           String
  name           String
  description    String?
  bundlePrice    Decimal @map("bundle_price") @db.Decimal(18, 4)

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  items        BundleItem[]

  @@unique([organizationId, code])
  @@map("promo_product_bundles")
}

model BundleItem {
  id        String @id @default(uuid())
  bundleId  String @map("bundle_id")
  productId String @map("product_id")
  quantity  Int    @default(1)

  bundle  ProductBundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([bundleId])
  @@index([productId])
  @@map("promo_bundle_items")
}

// ==========================================
// 5. PRICING MATRIX & CUSTOMER SEGMENTS
// ==========================================

model CustomerSegment {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  code           String
  name           String
  description    String?
  criteria       String // JSON defining the dynamic rules (e.g., LTV > 10000)

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  priceRules   PriceRule[]

  @@unique([organizationId, code])
  @@map("promo_customer_segments")
}

model PriceRule {
  id             String  @id @default(uuid())
  organizationId String  @map("organization_id")
  segmentId      String  @map("segment_id")
  productId      String? @map("product_id")
  categoryId     String? @map("category_id")

  adjustmentType String  @map("adjustment_type") // FIXED_PRICE, DISCOUNT_PERCENT, DISCOUNT_AMOUNT
  value          Decimal @db.Decimal(18, 4)
  minQuantity    Int     @default(1) @map("min_quantity")

  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  status    RecordStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  segment      CustomerSegment  @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  product      Product?         @relation(fields: [productId], references: [id], onDelete: Cascade)
  category     ProductCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([organizationId, segmentId])
  @@index([productId])
  @@index([categoryId])
  @@map("promo_price_rules")
}

model Translation {
  id             String @id @default(uuid())
  organizationId String @map("organization_id")
  locale         String // e.g. "th", "en"
  key            String // dot-namespaced key, e.g. "customers.title"
  value          String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, locale, key], map: "uk_translation_org_locale_key")
  @@index([organizationId, locale])
  @@map("translations")
}
